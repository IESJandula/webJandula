# ============================================================
# Backend API - IES Jándula Noticias
# ============================================================

# Puerto del servidor
PORT=3001

# Ruta de la base de datos SQLite (Prisma)
# En local, relativa a esta carpeta. En producción/Dokploy, apunta al volumen persistente:
# DATABASE_URL=file:/data/jandula-noticias.db
DATABASE_URL=file:./jandula-noticias.db

# URL pública del backend (para construir URLs de imágenes)
PUBLIC_URL=http://localhost:3001

# Credenciales Firebase Admin SDK — elige UNA de las dos opciones:
#
# OPCIÓN A – Producción / Dokploy (recomendado):
# Pega aquí el contenido entero del JSON de service account, en una sola línea
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"guardias-ies-jandula",...}
#
# OPCIÓN B – Desarrollo local:
# Ruta al fichero JSON (descárgalo desde Firebase Console → Cuentas de servicio)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Emails de administradores separados por coma (mismos que en guardias)
ADMIN_EMAILS=admin@g.educaand.es

# URL del frontend Astro (para CORS)
FRONTEND_URL=http://localhost:4321

# URL del panel Vue (para CORS)
PANEL_URL=http://localhost:5173

# Carpeta donde se guardan las imágenes subidas
# En producción apunta al volumen de Dokploy
UPLOADS_DIR=./uploads
