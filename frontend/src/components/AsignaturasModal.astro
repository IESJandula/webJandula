---
// Modal de asignaturas para ciclos formativos — incluye el script de interacción
---

<div id="asignaturas-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
  <div id="asignaturas-overlay" class="absolute inset-0 bg-slate-900/60"></div>
  <div class="relative mx-auto mt-12 w-[92%] max-w-2xl rounded-2xl bg-white shadow-2xl ring-1 ring-slate-200 sm:mt-20">
    <div class="flex items-start justify-between border-b border-slate-200 px-6 py-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Plan de estudios</p>
        <h3 id="modal-title" class="mt-1 text-lg font-bold text-slate-900">Asignaturas del ciclo</h3>
      </div>
      <button
        id="close-asignaturas-modal"
        type="button"
        class="rounded-lg p-2 text-slate-500 transition hover:bg-slate-100 hover:text-slate-700"
        aria-label="Cerrar modal"
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>
    <div class="grid grid-cols-1 gap-5 p-6 md:grid-cols-2">
      <section class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-200/80">
        <h4 class="text-sm font-semibold text-slate-900">1º curso</h4>
        <ul id="modal-primero" class="mt-3 space-y-2 text-sm text-slate-700"></ul>
      </section>
      <section class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-200/80">
        <h4 class="text-sm font-semibold text-slate-900">2º curso</h4>
        <ul id="modal-segundo" class="mt-3 space-y-2 text-sm text-slate-700"></ul>
      </section>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('asignaturas-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalPrimero = document.getElementById('modal-primero');
    const modalSegundo = document.getElementById('modal-segundo');
    const closeBtn = document.getElementById('close-asignaturas-modal');
    const overlay = document.getElementById('asignaturas-overlay');

    const renderList = (container: Element | null, items: string[]) => {
      if (!container) return;
      container.innerHTML = '';
      const materias = items.length ? items : ['No disponible por el momento.'];
      materias.forEach((materia) => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2';
        li.innerHTML = '<span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>' + materia;
        container.appendChild(li);
      });
    };

    const openModal = (name: string, asignaturas: { primero?: string[]; segundo?: string[] }) => {
      if (!modal) return;
      if (modalTitle) modalTitle.textContent = `Asignaturas - ${name}`;
      renderList(modalPrimero, asignaturas.primero ?? []);
      renderList(modalSegundo, asignaturas.segundo ?? []);
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
    };

    document.querySelectorAll<HTMLButtonElement>('.open-asignaturas-modal').forEach((btn) => {
      btn.addEventListener('click', () => {
        const ciclo = btn.getAttribute('data-ciclo') ?? 'Ciclo formativo';
        let asignaturas = { primero: [] as string[], segundo: [] as string[] };
        try {
          asignaturas = JSON.parse(btn.getAttribute('data-asignaturas') ?? '{}');
        } catch { /* empty */ }
        openModal(ciclo, asignaturas);
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  });
</script>
