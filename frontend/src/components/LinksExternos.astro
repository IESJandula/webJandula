---
import ContactoModal from "@/components/ContactoModal.astro";

type EnlaceExterno = {
  nombre: string;
  link: string;
  svg: string;
};


let accessLinks: EnlaceExterno[] = [
  {
    nombre: 'Séneca',
    link: 'https://www.juntadeandalucia.es/educacion/seneca',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25m0 0H5.25A2.25 2.25 0 017.5 9.75M3 13.125v6.75C3 20.496 3.504 21 4.125 21h17.25c.621 0 1.125-.504 1.125-1.125v-6.75m-15-3h9m0 0a2.25 2.25 0 012.25 2.25m0 0a2.25 2.25 0 01-2.25 2.25m0 0H9.25a2.25 2.25 0 01-2.25-2.25m0 0a2.25 2.25 0 012.25-2.25m0 0H5.25A2.25 2.25 0 013 9.75"/></svg>'
  },
  {
    nombre: 'Moodle',
    link: 'https://moodle.iesjandula.es',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>'
  },
  {
    nombre: 'Intranet',
    link: 'https://intranet.iesjandula.es',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>'
  },
]

---

<div class="bg-gradient-to-r from-jandula-green via-teal-500 to-jandula-blue relative overflow-hidden" aria-label="Accesos rápidos institucionales" role="navigation">
  <!-- Efecto de fondo decorativo sutil -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-white rounded-full mix-blend-multiply filter blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-white rounded-full mix-blend-multiply filter blur-3xl"></div>
  </div>

  <div class="container">
    <div class="flex flex-row justify-end gap-2 sm:gap-3 px-2 sm:px-4 py-2 sm:py-2.5">
      <!-- Botón Contacto - IDÉNTICO a los demás -->
      <ContactoModal
        id="contacto-links-externos"
        triggerText=""
        triggerClass="group relative gap-1 inline-flex items-center justify-center px-2 sm:px-3.5 py-2 sm:py-2.5 text-xs sm:text-sm font-semibold !text-white backdrop-blur-md transition-all duration-200 ease-out hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 whitespace-nowrap w-full sm:w-auto"
        
        
      >
        <svg
          class="relative z-10 h-4 w-4 sm:h-5 sm:w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 7.5v9a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25v-9m19.5 0A2.25 2.25 0 0019.5 5.25h-15A2.25 2.25 0 002.25 7.5m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0l-7.5-4.615A2.25 2.25 0 012.25 7.743V7.5"
          />
        </svg>
        <span class="relative z-10">Contacto</span>
      </ContactoModal>

      <!-- Enlaces de acceso rápido -->
      {accessLinks.map((dato) => (
        <a
          href={dato.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative gap-1 inline-flex items-center justify-center px-2 sm:px-3.5 py-2 sm:py-2.5 text-xs sm:text-sm font-semibold !text-white backdrop-blur-md transition-all duration-200 ease-out hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 whitespace-nowrap w-full sm:w-auto"
          aria-label={`${dato.nombre} (abre en nueva ventana)`}
          title={dato.nombre}
        >
          <!-- SVG visible solo en tablet y desktop -->
          <div class="hidden sm:flex w-5 h-5 mb-1 text-white relative z-10 group-hover:scale-110 transition-transform duration-200">
            <Fragment set:html={dato.svg} />
          </div>
          <span class="relative z-10">{dato.nombre}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  div[role="navigation"] {
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 4px 12px rgba(0, 0, 0, 0.1);
  }

  @supports (backdrop-filter: blur(10px)) {
    div[role="navigation"] {
      background: linear-gradient(135deg, rgba(163, 204, 42, 0.85) 0%, rgba(93, 178, 162, 0.85) 100%);
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  div[role="navigation"] {
    animation: slideDown 0.5s ease-out;
  }
</style>

