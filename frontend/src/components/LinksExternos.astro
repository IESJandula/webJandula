---

type EnlaceExterno = {
  nombre: string;
  link: string;
  icon?: string;
};

const { PUBLIC_API_URL } = import.meta.env;

// Iconos SVG inline por nombre de enlace (fallback elegante)
const iconMap: Record<string, string> = {
  'Contacto': `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  /* eslint-disable-next-line */
  'Acceso S\u00E9neca': `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
  'Moodle': `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
  'Intranet': `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
};

const defaultIcon = `<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>`;

let accessLinks: EnlaceExterno[] = [
  {
    nombre: 'Contacto',
    link: 'https://moodle.iesjandula.es/contacto'
  },
  {
    nombre: 'Acceso Séneca',
    link: 'https://www.juntadeandalucia.es/educacion/seneca'
  },
  {
    nombre: 'Moodle',
    link: 'https://moodle.iesjandula.es'
  },
  {
    nombre: 'Intranet',
    link: 'https://intranet.iesjandula.es'
  },
  ]


---

<div
  class="bg-gradient-to-r from-jandula-green to-jandula-blue border-b border-white/10"
  aria-label="Accesos rápidos institucionales"
  role="navigation"
>
  <div class="container flex items-center justify-end h-9 gap-0.5">
    {accessLinks.map((dato, i) => (
      <>
        {i > 0 && (
          <span class="text-white/20 select-none px-0.3" aria-hidden="true">|</span>
        )}
        <a 
          href={dato.link}
          target={dato.link.startsWith('http') ? '_blank' : undefined}
          rel={dato.link.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="group inline-flex items-center gap-1.5 px-3 py-1 rounded text-xs font-medium text-white/85 hover:text-white hover:bg-white/10 transition-all duration-150 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-1 focus-visible:ring-offset-transparent"
          aria-label={`${dato.nombre} (abre en nueva ventana)`}
        >
          <Fragment set:html={iconMap[dato.nombre] ?? defaultIcon} />
          <span>{dato.nombre}</span>
        </a>
      </>
    ))}
  </div>
</div>

