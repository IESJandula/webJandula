---
import LogoJuntaDeAndalucia from "@components/LogoJuntaDeAndalucia.astro";
import ContactoModal from "@/components/ContactoModal.astro";
import { socialLinks } from "@/lib/content";

const quickLinks = [
  { name: "Aviso Legal", href: "/aviso-legal" },
  { name: "Política de Privacidad", href: "/privacidad" },
  { name: "Mapa del Sitio", href: "/sitemap" },
  { name: "Accesibilidad", href: "/accesibilidad" },
];

const logosfooter = [
  {
    name: "Andalucía se mueve con Europa",
    href: "images/AndaluaciaEuropa.webp",
  },
  { name: "Junta de Andalucía", href: "images/logo-ced.png" },
];

const year = new Date().getFullYear();
---

<footer
  class="bg-white"
  role="contentinfo"
  aria-label="Información y navegación secundaria del IES Jándula"
>
  <div
    class="text-white py-6 flex flex-row items-center justify-between gap-8 container"
  >
    {
      logosfooter.map((logo) => (
        <img
          src={logo.href}
          alt={`Logo de ${logo.name}`}
          class="h-12 md:h-18 w-auto no-select-img"
        />
      ))
    }
  </div>

  <div
    class="bg-gradient-to-r from-jandula-blue to-jandula-green text-white py-8"
  >
    <div class="container">
      <div class="flex flex-col md:flex-row justify-between items-center mb-6">
        <div class="flex space-x-4 mb-4 md:mb-0">
          {
            socialLinks.map((link) => {
              const Icon = link.component;
              return (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Síguenos en ${link.name}`}
                  class="text-white/80 hover:text-white transition-colors hover:scale-110 transform duration-300"
                >
                  <Icon />
                </a>
              );
            })
          }
        </div>

        <nav
          class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-sm font-medium"
        >
          {
            quickLinks.map((link) => (
              <a
                href={link.href}
                class="hover:text-black transition-colors py-1 px-2"
              >
                {link.name}
              </a>
            ))
          }

          <ContactoModal
            id="contacto-footer"
            triggerText=""
            triggerClass="hover:text-black transition-colors py-1 px-2"
          >

              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 7.5v9a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25v-9m19.5 0A2.25 2.25 0 0019.5 5.25h-15A2.25 2.25 0 002.25 7.5m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0l-7.5-4.615A2.25 2.25 0 012.25 7.743V7.5"
              ></path>
            </svg>
            <span class="relative z-10 text-sm">Contacto</span>
          </ContactoModal>
        </nav>
      </div>

      <div
        class="text-center text-xs text-white border-t border-gray-700 pt-4 mt-4"
      >
        <p>&copy; {year} IES Jándula. Todos los derechos reservados.</p>
        <p class="mt-1">
          Centro acogido a la Ley Orgánica de Protección de Datos (RGPD) y
          regulaciones de la Junta de Andalucía.
        </p>
      </div>
    </div>
  </div>
</footer>
