---
import LogoJuntaDeAndalucia from "@components/LogoJuntaDeAndalucia.astro";
import { socialLinks } from "@/lib/content";

const quickLinks = [
    {name: 'Aviso Legal', href: '/aviso-legal'},
    {name: 'Política de Privacidad', href: '/privacidad'},
    {name: 'Mapa del Sitio', href: '/sitemap'},
    {name: 'Accesibilidad', href: '/accesibilidad'},
    {name: 'Contacto', href: '/contacto'},
];


const logosfooter = [
    {name: 'Andalucía se mueve con Europa', href: 'images/AndaluaciaEuropa.webp'},
    {name: 'Junta de Andalucía', href: 'images/logo-ced.png'},
];

const year = new Date().getFullYear();
---

<footer class="bg-white" role="contentinfo" aria-label="Información y navegación secundaria del IES Jándula">

    <div class="text-white py-6 flex flex-row items-center justify-between gap-8 container">
            {logosfooter.map((logo) => (
                        <img src={logo.href} alt={`Logo de ${logo.name}`} class="h-12 md:h-18 w-auto no-select-img"/>
    
            ))}

    </div>

    <div class="bg-gradient-to-r from-jandula-blue to-jandula-green text-white py-8">
        <div class="container">
            <div class="flex flex-col md:flex-row justify-between items-center mb-6">

                <div class="flex space-x-4 mb-4 md:mb-0">
                    {socialLinks.map((link) => {
                        const Icon = link.component;
                        return (
                                <a
                                        href={link.href}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        aria-label={`Síguenos en ${link.name}`}
                                        class="text-white/80 hover:text-white transition-colors hover:scale-110 transform duration-300"
                                >
                                    <Icon />
                                </a>
                        );
                    })}
                </div>

                <nav class="flex flex-wrap justify-center space-x-4 text-sm font-medium">
                    {quickLinks.map((link) => (
                            <a
                                    href={link.href}
                                    class="hover:text-black transition-colors py-1 px-2"
                            >
                                {link.name}
                            </a>
                    ))}
                </nav>
            </div>

            <div class="text-center text-xs text-white border-t border-gray-700 pt-4 mt-4">
                <p>&copy; {year} IES Jándula. Todos los derechos reservados.</p>
                <p class="mt-1">
                    Centro acogido a la Ley Orgánica de Protección de Datos (RGPD) y regulaciones de la Junta de
                    Andalucía.
                </p>
            </div>
        </div>
    </div>
</footer>