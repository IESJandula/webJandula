---
// src/components/CardNoticia.astro
interface Props {
    title: string;
    summary: string;
    date: string;
    image: string;
    category: string;
    link: string;
    variant?: 'default' | 'featured';
}

const { title, summary, date, image, category, link, variant = 'default' } = Astro.props;
const isFeatured = variant === 'featured';
---

<article class="group flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm ring-1 ring-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full">

    <!-- ── Imagen ──────────────────────────────── -->
    <div class={`relative ${isFeatured ? 'h-64 md:h-72' : 'h-52'} flex-shrink-0 overflow-hidden`}>
        <img
            src={image}
            alt={`Fotografía de la noticia: ${title}`}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
        />
        <!-- Gradiente para legibilidad -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent pointer-events-none" aria-hidden="true"></div>

        <!-- Badge categoría -->
        <span
            class="absolute top-3 left-3 inline-flex items-center bg-white/90 backdrop-blur-sm text-blue-700 text-[11px] font-bold px-2.5 py-1 rounded-full ring-1 ring-blue-100 uppercase tracking-wide shadow-sm"
            aria-hidden="true"
        >
            {category}
        </span>

        <!-- Fecha flotante sobre la imagen -->
        <time
            datetime={date}
            class="absolute bottom-3 right-3 inline-flex items-center gap-1.5 text-white/90 text-[11px] font-medium bg-black/40 backdrop-blur-sm px-2.5 py-1 rounded-full"
        >
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {date}
        </time>
    </div>

    <!-- ── Contenido ───────────────────────────── -->
    <div class={`flex flex-col flex-grow ${isFeatured ? 'p-6 gap-3' : 'p-5 gap-2.5'}`}>

        <h3 class={`${isFeatured ? 'text-lg md:text-xl' : 'text-[15px]'} font-bold text-gray-900 leading-snug line-clamp-2 group-hover:text-blue-700 transition-colors`}>
            <a
                href={link}
                class="focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 rounded"
            >
                {title}
            </a>
        </h3>

        <p class={`${isFeatured ? 'text-[15px] line-clamp-4' : 'text-sm line-clamp-3'} text-gray-500 leading-relaxed flex-grow`}>
            {summary}
        </p>

        <!-- CTA -->
        <div class="pt-3 mt-auto border-t border-gray-100">
            <a
                href={link}
                aria-label={`Leer noticia completa: ${title}`}
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 rounded"
            >
                Leer noticia
                <svg
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                    fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
            </a>
        </div>
    </div>
</article>

