---
interface Props {
  nombre: string;
  nivel: string;
  familia: string;
  descripcion: string;
  duracion: string;
  turno: string;
  enlace: string;
  bilingue?: string;
  imagen?: { url: string; alternativeText?: string };
  asignaturas?: { primero?: string[]; segundo?: string[] };
}

const { nombre, nivel, familia, descripcion, duracion, turno, enlace, bilingue, imagen, asignaturas } = Astro.props;

const nivelBadge = nivel.includes('Superior')
  ? 'bg-purple-600 ring-purple-600/20'
  : nivel.includes('Medio')
    ? 'bg-blue-600 ring-blue-600/20'
    : 'bg-green-600 ring-green-600/20';
---

<div
  data-familia={familia}
  class="ciclo-card group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white transition-all hover:shadow-xl hover:shadow-slate-200/50 hover:-translate-y-1 ring-1 ring-slate-100"
>
  <div>
    <div class="relative w-full h-44 bg-blue-500">
      <img
        src={imagen?.url ?? '/fallback-banner.jpg'}
        alt={imagen?.alternativeText ?? `Imagen del ciclo formativo: ${nombre}`}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      <span
        aria-hidden="true"
        class={`absolute top-4 right-4 text-white inline-flex items-center rounded-full px-2.5 py-0.5 text-s font-semibold ring-1 ring-inset ${nivelBadge}`}
      >
        {nivel.replace('Grado ', '')}
      </span>
    </div>

    <div class="p-7 bg-white w-full">
      <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors duration-300 leading-tight">
        {nombre}
      </h3>
      <p class="mt-4 text-sm leading-relaxed text-slate-500">{descripcion}</p>

      <div class="mt-6 w-full border-t border-slate-100 pt-6">
        <div class="flex flex-wrap items-start gap-2">
          <span class="inline-flex items-center gap-1.5 rounded-md bg-slate-50 px-2 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
            <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {duracion}
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-md bg-slate-50 px-2 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
            <svg class="h-3.5 w-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            {turno}
          </span>
          {bilingue && (
            <span class="inline-flex items-center gap-1.5 rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-200/80">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m10.5 21 5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802" />
              </svg>
              Bilingüe: {bilingue}
            </span>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="px-7 pb-7 pt-2 grid grid-cols-1 sm:grid-cols-2 gap-3">
    <a
      href={enlace}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-500"
    >
      Ver ciclo
    </a>
    <button
      type="button"
      class="open-asignaturas-modal inline-flex items-center justify-center rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700 ring-1 ring-slate-200 transition hover:bg-slate-200"
      data-ciclo={nombre}
      data-asignaturas={JSON.stringify(asignaturas ?? { primero: [], segundo: [] })}
    >
      Ver módulos
    </button>
  </div>
</div>
