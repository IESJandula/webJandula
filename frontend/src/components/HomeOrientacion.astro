---
import SectionHeader from './SectionHeader.astro';

const tarjetas = [
  {
    bg: 'from-emerald-50 to-teal-50 border-emerald-100',
    iconBg: 'bg-emerald-600',
    title: 'Acción Tutorial',
    desc: 'Seguimiento personalizado del alumnado, técnicas de estudio y orientación académica y profesional para decidir su futuro.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />`,
    colSpan: '',
  },
  {
    bg: 'from-blue-50 to-indigo-50 border-blue-100',
    iconBg: 'bg-blue-600',
    title: 'Atención a la Diversidad',
    desc: 'Educación inclusiva con medidas y recursos específicos que se adaptan a las necesidades de cada estudiante.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />`,
    colSpan: '',
  },
  {
    bg: 'from-purple-50 to-pink-50 border-purple-100',
    iconBg: 'bg-purple-600',
    title: 'Comunidad Educativa',
    desc: 'Familias, AMPA y Consejo de Estudiantes: una comunidad que participa y construye el centro día a día.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />`,
    colSpan: 'md:col-span-2 lg:col-span-1',
  },
];
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <SectionHeader
      eyebrow="Orientación y Comunidad"
      eyebrowClass="bg-teal-50 text-teal-700"
      title="Apoyo integral al alumnado"
      subtitle="Acompañamiento educativo, atención personalizada y participación activa de toda la comunidad escolar"
    />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {tarjetas.map((t) => (
        <div class={`bg-gradient-to-br ${t.bg} rounded-2xl p-8 border ${t.colSpan}`}>
          <div class={`w-12 h-12 ${t.iconBg} rounded-xl flex items-center justify-center mb-6`}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white" set:html={t.icon} />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{t.title}</h3>
          <p class="text-gray-600">{t.desc}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/orientacion" class="inline-block bg-teal-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-teal-700 transition-colors">
        Más información
      </a>
    </div>
  </div>
</section>
