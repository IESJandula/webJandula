---
// src/components/QuickAccess.astro
const accessItems = [
    {
        name: 'Moodle',
        label: 'Plataforma educativa',
        href: 'https://moodle.iesjandula.es',
        accent: '#ea7317',
        iconPath: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
    },
    {
        name: 'Séneca',
        label: 'Portal Junta de Andalucía',
        href: 'https://www.juntadeandalucia.es/educacion/seneca/',
        accent: '#16a34a',
        iconPath: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    },
    {
        name: 'Intranet',
        label: 'Área de profesorado',
        href: 'https://sites.google.com/g.educaand.es/ies-jandula/inicio',
        accent: '#1D829B',
        iconPath: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
    },
    {
        name: 'Secretaría',
        label: 'Trámites y certificados',
        href: '/secretaria_virtual',
        accent: '#7c3aed',
        iconPath: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    },
];
---

<section class="container mx-auto px-4 relative z-20 -mt-16 mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        {accessItems.map((item) => (
            <a
                href={item.href}
                target={item.href.startsWith('http') ? '_blank' : '_self'}
                rel="noopener noreferrer"
                class="group relative bg-white rounded-2xl shadow-md hover:shadow-xl p-5 flex flex-col items-center justify-center text-center transition-all duration-300 hover:-translate-y-1 overflow-hidden border border-slate-100"
            >
                <!-- Barra de acento superior que aparece en hover -->
                <div
                    class="absolute top-0 left-0 right-0 h-0.5 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-t-2xl"
                    style={`background: ${item.accent};`}
                    aria-hidden="true"
                ></div>

                <!-- Icono -->
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 bg-slate-50 group-hover:bg-white transition-colors duration-300">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6 transition-transform duration-300 group-hover:scale-110"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="1.75"
                        style={`color: ${item.accent};`}
                    >
                        <path stroke-linecap="round" stroke-linejoin="round" d={item.iconPath} />
                    </svg>
                </div>

                <span class="font-bold text-slate-800 text-sm leading-tight">{item.name}</span>
                <span class="text-xs text-slate-400 mt-0.5 hidden md:block">{item.label}</span>
            </a>
        ))}
    </div>
</section>