---
import Logo from "@components/Logo.astro";

const menuItems = [
  {
    name: "Nuestro Centro",
    href: "/nuestro_centro",
  },
  {
    name: "Oferta Educativa",
    href: "/oferta",
  },
  {
    name: "Proyectos",
    href: "/proyectos",
  },
  {
    name: "Internacional",
    href: "/internacionalizacion",
  },
  {
    name: "Orientación",
    href: "/orientacion",
  },
  {
    name: "Secretaría Virtual",
    href: "/secretaria_virtual",
  },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm sticky top-0 z-50" role="banner">
  <nav class="container py-0 flex items-center justify-between h-20" aria-label="Navegación principal">

    <!-- Logo -->
    <a
      href="/"
      class="flex items-center font-extrabold text-blue-900 transition-opacity hover:opacity-80 flex-shrink-0"
      aria-label="Inicio — IES Jándula"
    >
      <Logo class="size-20" />
    </a>

    <!-- Desktop menu -->
    <ul class="hidden lg:flex items-center gap-1 h-full" role="menubar" aria-label="Menú principal">
      {menuItems.map((item) => (
        <li class="h-full flex items-center" role="none">
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-1
              ${currentPath === item.href
                ? 'text-blue-700 bg-blue-50'
                : 'text-gray-700 hover:text-blue-700 hover:bg-gray-50'}
            `}
            role="menuitem"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger Button (mobile) -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 rounded-xl text-gray-600 hover:bg-gray-100 transition-colors"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-gray-100 bg-white max-h-[80vh] overflow-y-auto"
    aria-label="Menú móvil"
  >
    <ul class="container py-3 space-y-1">
      {menuItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`block px-4 py-3 rounded-xl text-sm font-semibold transition-colors
              ${currentPath === item.href
                ? 'text-blue-700 bg-blue-50'
                : 'text-gray-800 hover:bg-gray-50'}
            `}
            data-mobile-link
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // ── Hamburger toggle ──────────────────────────────────────────
  const menuToggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconOpen   = document.getElementById('icon-open')   as SVGElement | null;
  const iconClose  = document.getElementById('icon-close')  as SVGElement | null;

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuToggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Cierra el menú móvil tras navegar a una sección.
  document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
