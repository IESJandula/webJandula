---
import SectionHeader from './SectionHeader.astro';

const tarjetas = [
  {
    href: '/secretaria_virtual#matricula',
    iconBg: 'bg-blue-100',
    iconColor: 'text-blue-600',
    hoverTitle: 'group-hover:text-blue-700',
    title: 'Matrícula Online',
    desc: 'Formaliza tu matrícula de forma rápida y 100% online.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
  },
  {
    href: '/secretaria_virtual#certificados',
    iconBg: 'bg-emerald-100',
    iconColor: 'text-emerald-600',
    hoverTitle: 'group-hover:text-emerald-700',
    title: 'Solicitud de Documentos',
    desc: 'Certificados, títulos y documentación académica.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />`,
  },
  {
    href: '/secretaria_virtual#becas',
    iconBg: 'bg-purple-100',
    iconColor: 'text-purple-600',
    hoverTitle: 'group-hover:text-purple-700',
    title: 'Becas y Ayudas',
    desc: 'Información y solicitud de ayudas económicas.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />`,
  },
];
---

<section class="py-20 bg-gradient-to-br from-slate-50 to-blue-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center">
      <SectionHeader
        eyebrow="Secretaría"
        eyebrowClass="bg-blue-50 text-blue-700"
        title="Gestión online al alcance de todos"
        subtitle="Realiza tus trámites administrativos desde cualquier lugar y en cualquier momento, sin colas ni esperas."
      />

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        {tarjetas.map((t) => (
          <a href={t.href} class="group block bg-white rounded-2xl p-6 shadow-sm ring-1 ring-gray-100 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
            <div class={`w-14 h-14 ${t.iconBg} rounded-xl flex items-center justify-center mx-auto mb-4 transition-transform duration-300 group-hover:scale-110`}>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class={`w-7 h-7 ${t.iconColor}`} set:html={t.icon} />
            </div>
            <h3 class={`font-bold text-gray-900 mb-2 transition-colors ${t.hoverTitle}`}>{t.title}</h3>
            <p class="text-gray-600 text-sm">{t.desc}</p>
          </a>
        ))}
      </div>

      <a href="/secretaria_virtual" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-blue-700 transition-colors">
        Acceder a Secretaría
      </a>
    </div>
  </div>
</section>
