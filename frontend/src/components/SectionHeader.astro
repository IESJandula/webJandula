---
interface Props {
  eyebrow: string;
  eyebrowClass: string;
  title: string;
  subtitle: string;
  dark?: boolean;
}

const { eyebrow, eyebrowClass, title, subtitle, dark = false } = Astro.props;
---

<div class="text-center mb-12">
  <span class={`inline-block px-4 py-2 rounded-full text-sm font-semibold mb-4 ${eyebrowClass}`}>
    {eyebrow}
  </span>
  <h2 class={`text-4xl font-bold mb-4 ${dark ? 'text-white' : 'text-gray-900'}`}>
    {title}
  </h2>
  <p class={`text-lg max-w-2xl mx-auto ${dark ? 'text-blue-100 leading-relaxed' : 'text-gray-600'}`}>
    {subtitle}
  </p>
</div>
