---
import SectionHeader from './SectionHeader.astro';

const programas = [
  {
    href: '/internacionalizacion#erasmus',
    title: 'Erasmus+',
    desc: 'Movilidades, intercambio cultural y aprendizaje lingüístico real por toda Europa.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3M3.6 9h16.8M3.6 15h16.8" />`,
  },
  {
    href: '/internacionalizacion#erasmus',
    title: 'Erasmus+ FP',
    desc: 'Prácticas profesionales en empresas extranjeras que impulsan la empleabilidad.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />`,
  },
  {
    href: '/internacionalizacion#etwinning',
    title: 'eTwinning',
    desc: 'Colaboración digital y proyectos hermanados en tiempo real con aulas de toda Europa.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />`,
  },
  {
    href: '/internacionalizacion#embajadoras',
    title: 'Escuela Embajadora',
    desc: 'Del Parlamento Europeo: formamos ciudadanía viviendo de cerca los valores y la democracia de la UE.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />`,
  },
];
---

<section class="relative py-20 bg-gradient-to-br from-blue-900 to-indigo-900 text-white overflow-hidden">
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-blue-500/20 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="container mx-auto px-4 relative">
    <SectionHeader
      eyebrow="Internacionalización"
      eyebrowClass="bg-blue-700 text-blue-100"
      title="Abriendo fronteras, construyendo futuro"
      subtitle="Un centro abierto al mundo. Derribamos las barreras del aula tradicional participando en redes europeas e iniciativas internacionales que convierten el aprendizaje en una experiencia global para nuestro alumnado y profesorado."
      dark={true}
    />

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {programas.map((p) => (
        <a href={p.href} class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 flex flex-col">
          <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true" set:html={p.icon} />
          </div>
          <h3 class="font-bold text-lg mb-2">{p.title}</h3>
          <p class="text-blue-100 text-sm leading-relaxed flex-grow">{p.desc}</p>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/internacionalizacion" class="inline-block bg-white text-blue-900 px-8 py-3 rounded-full font-semibold hover:bg-blue-50 transition-colors">
        Conoce nuestro programa internacional
      </a>
    </div>
  </div>
</section>
