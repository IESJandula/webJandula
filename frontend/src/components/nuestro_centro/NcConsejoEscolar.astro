---
const miembros = [
  { count: 1, label: 'Presidencia' },
  { count: 8, label: 'Profesorado' },
  { count: 4, label: 'Familias' },
  { count: 4, label: 'Alumnado' },
  { count: 1, label: 'Ayuntamiento' },
];
---

<div id="consejoescolar" class="md:col-span-3 rounded-3xl bg-white border border-slate-200 p-8 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex flex-col sm:items-center gap-4 mb-6 justify-between">
    <div class="flex flex-row justify-between sm:items-start gap-4 w-full">
      <h3 class="text-xl font-bold text-gray-900 flex items-center gap-3">
        <span class="p-2 bg-emerald-100 text-emerald-700 rounded-lg">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
        </span>
        Consejo Escolar
      </h3>
      <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
        Órgano de Participación
      </span>
    </div>
    <p class="mt-2 text-sm text-gray-500 leading-relaxed w-full justify-start">
      El <strong>Consejo Escolar</strong> es el máximo órgano de representación y decisión del centro. Está compuesto por representantes de todos los sectores de la comunidad educativa (equipo directivo, profesorado, alumnado, familias, personal de administración y servicios y ayuntamiento) y se reúne regularmente para analizar y tomar decisiones sobre aspectos fundamentales de la vida del centro.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
    {miembros.map((m) => (
      <div class="text-center p-4 bg-slate-50 rounded-2xl">
        <p class="text-2xl font-bold text-gray-900">{m.count}</p>
        <p class="text-xs text-gray-500 uppercase mt-1">{m.label}</p>
      </div>
    ))}
  </div>
</div>
