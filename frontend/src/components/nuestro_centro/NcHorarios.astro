---
import { horariosCentro, calendarioEscolar } from '@lib/content';
---

<div id="horarios" class="rounded-3xl bg-blue-900 p-8 shadow-xl text-white flex flex-col justify-between">
  <div>
    <h3 class="text-xl font-bold mb-6 flex items-center gap-3">
      <span class="p-2 bg-blue-800 rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
      Horarios
    </h3>
    <ul class="space-y-6">
      {horariosCentro.map((item) => (
        <li class="relative pl-4 border-l-2 border-emerald-400">
          <p class="text-blue-200 text-xs uppercase font-bold tracking-wide mb-1">{item.turno}</p>
          <p class="font-semibold text-lg">{item.horario}</p>
          {item.detalle && <span class="text-xs text-blue-200 block mt-1">{item.detalle}</span>}
        </li>
      ))}
    </ul>
  </div>
  <div class="pt-6 border-t border-blue-800">
    <p class="text-m text-blue-100 font-semibold">Calendario oficial del curso {calendarioEscolar.curso}</p>
    <p class="mt-2 text-sm text-blue-100">{calendarioEscolar.descripcion}</p>
    <a
      href={calendarioEscolar.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-emerald-300 hover:text-emerald-200 transition-colors"
    >
      Consultar calendario oficial
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</div>
