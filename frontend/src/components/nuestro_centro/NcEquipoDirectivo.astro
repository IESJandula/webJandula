---
import { equipodirectivo } from '@lib/content';
---

<div id="equipodirectivo" class="md:col-span-2 rounded-3xl bg-slate-50 p-8 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md">
  <h3 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-3">
    <span class="p-2.5 bg-blue-100 text-blue-700 rounded-xl">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
      </svg>
    </span>
    Equipo Directivo
  </h3>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {equipodirectivo.map((persona) => (
      <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 group hover:border-blue-200 transition-colors">
        <p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">{persona.cargo}</p>
        <p class="font-medium text-gray-900 group-hover:text-blue-700 transition-colors">{persona.nombre}</p>
      </div>
    ))}
  </div>

  <p class="mt-6 text-sm text-gray-500 leading-relaxed">
    El Equipo Directivo del IES Jándula es el órgano responsable de la gestión, organización y coordinación del centro. Trabaja de forma colegiada para garantizar el cumplimiento del Proyecto Educativo y la mejora continua de la calidad educativa.
  </p>

  <div class="mt-6 rounded-2xl">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Telefonos de contacto</p>
    <div class="mt-3 grid gap-2 sm:grid-cols-2">
      <p class="rounded-xl bg-white px-3 py-2 text-sm text-slate-700 ring-1 ring-slate-200">
        <span class="font-semibold text-slate-900">Conserjeria:</span> 953 53 95 08
      </p>
      <p class="rounded-xl bg-white px-3 py-2 text-sm text-slate-700 ring-1 ring-slate-200">
        <span class="font-semibold text-slate-900">Fax:</span> 953 53 95 11
      </p>
    </div>
  </div>
</div>
