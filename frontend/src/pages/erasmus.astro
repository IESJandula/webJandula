---
import Layout from "@layouts/Layout.astro";
import { acreditacion, proyectosErasmus, movilidadesFP } from "@lib/erasmus";

const tipoColores: Record<string, string> = {
  alumnado: "bg-blue-100 text-blue-800",
  profesorado: "bg-green-100 text-green-800",
  recepcion: "bg-purple-100 text-purple-800",
};

const tipoLabel: Record<string, string> = {
  alumnado: "Alumnado",
  profesorado: "Profesorado",
  recepcion: "Recepción",
};
---

<Layout title="Erasmus+ en el IES Jándula">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-700 via-blue-600 to-indigo-700 py-20">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-white -translate-x-1/2 translate-y-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white">
          <span>🇪🇺</span>
          <span>Programa Erasmus+</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
          Erasmus+ en el IES Jándula
        </h1>
        <p class="mt-6 text-lg text-blue-100">
          Desde el curso 2021-22, el IES Jándula cuenta con la Acreditación Erasmus+ para Educación Escolar, lo que nos permite desarrollar proyectos de movilidad de forma continuada hasta 2027. Aquí recogemos todas las experiencias vividas.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/internacionalizacion" class="inline-flex items-center gap-2 rounded-lg bg-white/20 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/30 transition-colors">
            ← Internacionalización
          </a>
          <a href="/etwinning" class="inline-flex items-center gap-2 rounded-lg bg-white text-blue-700 px-5 py-2.5 text-sm font-semibold hover:bg-blue-50 transition-colors">
            Ver proyectos eTwinning →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Badge acreditación -->
  <section class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-8">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 rounded-2xl bg-indigo-50 border border-indigo-100 p-6">
        <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-indigo-600 flex items-center justify-center text-2xl">
          🏅
        </div>
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-indigo-500 mb-1">{acreditacion.tipo}</p>
          <p class="text-gray-700 text-sm">{acreditacion.descripcion}</p>
        </div>
        <div class="flex-shrink-0 text-center bg-white rounded-xl px-6 py-3 border border-indigo-100 shadow-sm">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Vigencia</p>
          <p class="text-2xl font-bold text-indigo-700">{acreditacion.desde}–{acreditacion.hasta}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyectos por curso -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Movilidades de Educación Escolar</h2>
      <p class="text-gray-500 mb-12">Proyectos desarrollados con ESO y Bachillerato dentro de la Acreditación Erasmus+.</p>

      <div class="space-y-16">
        {proyectosErasmus.map((proyecto) => (
          <div>
            <!-- Cabecera del curso -->
            <div class="flex items-center gap-4 mb-6">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center rounded-full bg-blue-600 px-4 py-1 text-sm font-semibold text-white">
                  {proyecto.etiqueta}
                </span>
                <span class="text-xl font-bold text-gray-800">Curso {proyecto.curso}</span>
              </div>
              <div class="flex-1 h-px bg-gray-200"></div>
            </div>

            <!-- Movilidades -->
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {proyecto.movilidades.map((mov) => (
                <div class="relative bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow flex flex-col overflow-hidden">
                  {mov.fotos && mov.fotos.length > 0 ? (
                    <div class="relative h-44 overflow-hidden group">
                      <img
                        src={mov.fotos[0]}
                        alt={mov.titulo}
                        class="lb-img w-full h-full object-cover object-center cursor-zoom-in transition-transform duration-300 group-hover:scale-105"
                        loading="lazy"
                      />
                      {mov.fotos.length > 1 && (
                        <div class="absolute bottom-2 right-2 flex gap-1">
                          {mov.fotos.slice(1).map((foto) => (
                            <div class="w-10 h-10 rounded overflow-hidden ring-2 ring-white shadow cursor-zoom-in">
                              <img src={foto} alt={mov.titulo} class="lb-img w-full h-full object-cover object-center" loading="lazy" />
                            </div>
                          ))}
                        </div>
                      )}
                      <div class="absolute top-2 right-2">
                        <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium shadow ${tipoColores[mov.tipo]}`}>
                          {tipoLabel[mov.tipo]}
                        </span>
                      </div>
                      <!-- zoom icon hint -->
                      <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                        <div class="bg-black/40 rounded-full p-2">
                          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                        </div>
                      </div>
                    </div>
                  ) : (
                    <div class="h-44 bg-gradient-to-br from-blue-50 to-indigo-100 flex flex-col items-center justify-center gap-2 relative">
                      <svg class="w-8 h-8 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      <div class="flex flex-wrap justify-center gap-1.5 px-4">
                        {mov.paises.map((p) => (
                          <span class="text-xs font-semibold text-blue-600 bg-blue-100 px-2 py-0.5 rounded-full">{p}</span>
                        ))}
                      </div>
                      <div class="absolute top-2 right-2">
                        <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${tipoColores[mov.tipo]}`}>
                          {tipoLabel[mov.tipo]}
                        </span>
                      </div>
                    </div>
                  )}
                  <div class="p-4 flex flex-col gap-2 flex-1">
                    <div class="flex flex-wrap gap-1">
                      {mov.paises.map((p) => (
                        <span class="text-xs text-gray-400 font-medium">{p}</span>
                      ))}
                    </div>
                    <h3 class="font-semibold text-gray-900 text-sm leading-snug">{mov.titulo}</h3>
                    <p class="text-xs text-gray-500 leading-relaxed flex-1">{mov.descripcion}</p>
                    <div class="mt-auto pt-2 border-t border-gray-50 flex flex-wrap gap-x-4 gap-y-1">
                      <span class="text-xs text-gray-400 flex items-center gap-1">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        {mov.etapa}
                      </span>
                      {mov.participantes && (
                        <span class="text-xs text-gray-400 flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                          {mov.participantes}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Movilidades FP -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Movilidades de Formación Profesional</h2>
      <p class="text-gray-500 mb-12">FFE (Fase de Formación en Empresa) en el extranjero a través de los programas Talentum y Jaén+ de la Diputación de Jaén.</p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {movilidadesFP.map((mov) => (
          <div class="bg-white rounded-xl border border-orange-100 shadow-sm overflow-hidden flex flex-col">
            {mov.fotos && mov.fotos.length > 0 ? (
              <div class="relative h-36 overflow-hidden group">
                <img src={mov.fotos[0]} alt={mov.titulo} class="lb-img w-full h-full object-cover object-center cursor-zoom-in transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                {mov.fotos.length > 1 && (
                  <div class="absolute bottom-2 right-2 flex gap-1 flex-wrap max-w-[90%] justify-end">
                    {mov.fotos.slice(1, 5).map((foto) => (
                      <div class="w-9 h-9 rounded overflow-hidden ring-2 ring-white shadow cursor-zoom-in">
                        <img src={foto} alt={mov.titulo} class="lb-img w-full h-full object-cover object-center" loading="lazy" />
                      </div>
                    ))}
                    {mov.fotos.length > 5 && (
                      <div class="w-9 h-9 rounded overflow-hidden ring-2 ring-white shadow bg-black/60 flex items-center justify-center">
                        <span class="text-white text-xs font-bold">+{mov.fotos.length - 5}</span>
                      </div>
                    )}
                  </div>
                )}
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                  <div class="bg-black/40 rounded-full p-2">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
                  </div>
                </div>
              </div>
            ) : (
              <div class="h-36 bg-gradient-to-br from-orange-50 to-amber-100 flex flex-col items-center justify-center gap-2">
                <svg class="w-7 h-7 text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div class="flex flex-wrap justify-center gap-1">
                  {mov.paises.map((p) => <span class="text-xs font-semibold text-orange-600 bg-orange-100 px-2 py-0.5 rounded-full">{p}</span>)}
                </div>
              </div>
            )}
            <div class="p-4 flex flex-col gap-2 flex-1">
              <div class="flex items-center justify-between">
                <span class="inline-flex items-center rounded-full bg-orange-600 px-3 py-0.5 text-xs font-semibold text-white">
                  {mov.programa}
                </span>
                <span class="text-gray-400 text-xs">{mov.curso}</span>
              </div>
              <div class="flex flex-wrap gap-1">
                {mov.paises.map((p) => <span class="text-xs text-gray-400 font-medium">{p}</span>)}
              </div>
              <h3 class="font-semibold text-gray-900 text-sm leading-snug">{mov.titulo}</h3>
              <p class="text-xs text-gray-500 leading-relaxed flex-1">{mov.descripcion}</p>
              <p class="text-xs text-orange-700 font-medium border-t border-orange-100 pt-2">{mov.ciclo}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lb-overlay" class="fixed inset-0 z-50 hidden bg-black/90 items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Ver imagen ampliada">
    <button id="lb-close" aria-label="Cerrar" class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lb-prev" aria-label="Anterior" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white transition-colors hidden">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="lb-next" aria-label="Siguiente" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white transition-colors hidden">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
    <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl select-none" />
    <p id="lb-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm text-center max-w-lg"></p>
  </div>

  <script is:inline>
  (function () {
    var overlay = document.getElementById('lb-overlay');
    var lbImg   = document.getElementById('lb-img');
    var lbClose = document.getElementById('lb-close');
    var lbPrev  = document.getElementById('lb-prev');
    var lbNext  = document.getElementById('lb-next');
    var lbCap   = document.getElementById('lb-caption');

    var allImgs = [];
    var current = 0;

    function open(idx) {
      current = idx;
      var img = allImgs[idx];
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      lbCap.textContent = img.alt;
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      document.body.style.overflow = 'hidden';
      lbPrev.classList.toggle('hidden', allImgs.length <= 1);
      lbNext.classList.toggle('hidden', allImgs.length <= 1);
    }

    function close() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function prev() { open((current - 1 + allImgs.length) % allImgs.length); }
    function next() { open((current + 1) % allImgs.length); }

    document.addEventListener('DOMContentLoaded', function () {
      allImgs = Array.from(document.querySelectorAll('.lb-img'));
      allImgs.forEach(function (img, idx) {
        img.addEventListener('click', function () { open(idx); });
      });
    });

    lbClose.addEventListener('click', close);
    lbPrev.addEventListener('click', function(e) { e.stopPropagation(); prev(); });
    lbNext.addEventListener('click', function(e) { e.stopPropagation(); next(); });
    overlay.addEventListener('click', function (e) { if (e.target === overlay || e.target === lbImg) close(); });
    document.addEventListener('keydown', function (e) {
      if (!overlay.classList.contains('flex')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') prev();
      if (e.key === 'ArrowRight') next();
    });
  })();
  </script>

  <!-- CTA volver -->
  <section class="bg-blue-700 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <p class="text-blue-100 text-sm mb-4">¿Interesado en participar en nuestros próximos proyectos Erasmus+?</p>
      <h2 class="text-2xl font-bold text-white mb-6">Contacta con el Departamento de Internacionalización</h2>
      <a href="/internacionalizacion" class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-blue-700 hover:bg-blue-50 transition-colors">
        Ver más sobre internacionalización
      </a>
    </div>
  </section>
</Layout>
