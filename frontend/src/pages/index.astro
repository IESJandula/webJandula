---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import QuickAccess from '@components/QuickAccess.astro';
import CardNoticia from '@components/CardNoticia.astro';
import { getNoticias } from '@/lib/api';
import { caminosindex } from '@/lib/content';
import Chat from '@/components/Chat.astro';

const news = await getNoticias(5);

const sortedNews = [...news].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredNews = sortedNews.slice(0, 2);
const secondaryNews = sortedNews.slice(2, 5);

const getCaminoTheme = (color: string) => {
	// Tailwind necesita clases estáticas (no `text-${...}`), por eso este mapeo.
	switch (color) {
		case 'blue-500':
			return {
				badge: 'bg-blue-50 text-blue-700',
				title: 'text-blue-700',
				ring: 'group-hover:ring-blue-500/20',
			};
		case 'green-500':
			return {
				badge: 'bg-emerald-50 text-emerald-700',
				title: 'text-emerald-700',
				ring: 'group-hover:ring-emerald-500/20',
			};
		case 'purple-500':
			return {
				badge: 'bg-purple-50 text-purple-700',
				title: 'text-purple-700',
				ring: 'group-hover:ring-purple-500/20',
			};
		default:
			return {
				badge: 'bg-slate-50 text-slate-700',
				title: 'text-slate-900',
				ring: 'group-hover:ring-slate-400/20',
			};
	}
};
---


<!-- 	<Chat>

	</Chat> -->

<Layout title="Inicio">


	<Hero />
	
		<!-- Noticias -->
	{sortedNews.length > 0 && (
	<section class="container mx-auto px-4 py-20">
		<div class="flex flex-col md:flex-row justify-between items-end mb-8">
			<div>
				<h2 class="text-3xl font-bold text-gray-900">Últimas noticias</h2>
			</div>
			<a href="/noticias" class="hidden md:inline-block text-blue-600 font-bold hover:underline">
				Ver todas las noticias &rarr;
			</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
			{featuredNews.map((item) => (
				<CardNoticia {...item} variant="featured" />
			))}
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
			{secondaryNews.map((item) => (
				<CardNoticia {...item} />
			))}
		</div>

		<div class="mt-8 text-center md:hidden">
			<a href="/noticias" class="btn-secondary inline-block border border-blue-600 text-blue-600 px-6 py-2 rounded-full font-bold">
				Ver todo
			</a>
		</div>
	</section>
	)}

	<!-- Oferta Educativa -->
	<section class="py-20 bg-gradient-to-br from-slate-50 to-blue-50">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-emerald-50 text-emerald-700 text-sm font-semibold mb-4">
					Oferta Educativa
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Encuentra tu camino
				</h2>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
				{caminosindex.map((camino) => {
					const theme = getCaminoTheme(camino.color);
					return (
						<a
							href={camino.url}
							class={`group block h-full rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-jandula-blue/60 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-50`}
						>
							<div class={`h-full rounded-2xl bg-white border border-slate-200 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1 ${theme.ring}`}>
								<div class="p-8 flex h-full flex-col items-center text-center">
									<div class="aspect-square w-44 sm:w-52 overflow-hidden rounded-full bg-slate-100 mb-6 ring-4 ring-white shadow-md">
										<img
											src={camino.image}
											alt={camino.nombre}
											class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
											loading="lazy"
											decoding="async"
										/>
									</div>

									<h3 class={`text-2xl font-bold ${theme.title} inline-flex items-center gap-2`}>
										{camino.nombre}
										<svg class="w-5 h-5 opacity-0 -translate-x-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
										</svg>
									</h3>
								</div>
							</div>
						</a>
					);
				})}
			</div>

			<div class="text-center mt-12">
				<a href="/oferta" class="inline-block bg-emerald-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-emerald-700 transition-colors">
					Ver toda la oferta
				</a>
			</div>
		</div>
	</section>

	<!-- Proyectos -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-orange-50 text-orange-700 text-sm font-semibold mb-4">
					Proyectos
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Aprendemos haciendo
				</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Proyectos innovadores que enriquecen la formación de nuestro alumnado
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 p-8 text-white hover:scale-105 transition-transform">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Proyecto LINCE</h3>
						<p class="text-blue-100 mb-4">Participación en Shell Eco Marathon con vehículo de alta eficiencia</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>

				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-purple-600 to-pink-600 p-8 text-white hover:scale-105 transition-transform">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Revista "Pasa Página"</h3>
						<p class="text-purple-100 mb-4">Espacio de lectura, cultura y publicación de revista escolar</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>

				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-600 to-teal-600 p-8 text-white hover:scale-105 transition-transform md:col-span-2 lg:col-span-1">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Erasmus+</h3>
						<p class="text-emerald-100 mb-4">Movilidad europea para alumnado y profesorado de FP</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="/proyectos" class="inline-block bg-orange-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-orange-700 transition-colors">
					Ver todos los proyectos
				</a>
			</div>
		</div>
	</section>

	<!-- Internacionalización -->
	<section class="relative py-20 bg-gradient-to-br from-blue-900 to-indigo-900 text-white overflow-hidden">
		<div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-blue-500/20 blur-3xl pointer-events-none" aria-hidden="true"></div>
		<div class="container mx-auto px-4 relative">
			<div class="max-w-2xl mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-blue-700 text-blue-100 text-sm font-semibold mb-4">
					Internacionalización
				</span>
				<h2 class="text-4xl font-bold mb-6">
					Abriendo fronteras, construyendo futuro
				</h2>
				<p class="text-lg text-blue-100 leading-relaxed">
					Un centro abierto al mundo. Derribamos las barreras del aula tradicional participando en
					redes europeas e iniciativas internacionales que convierten el aprendizaje en una experiencia global
					para nuestro alumnado y profesorado.
				</p>
			</div>

			<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
				<!-- Erasmus+ -->
				<a href="/internacionalizacion#erasmus" class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 flex flex-col">
					<div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3M3.6 9h16.8M3.6 15h16.8" />
						</svg>
					</div>
					<h3 class="font-bold text-lg mb-2">Erasmus+</h3>
					<p class="text-blue-100 text-sm leading-relaxed flex-grow">Movilidades, intercambio cultural y aprendizaje lingüístico real por toda Europa.</p>
					<span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
						Saber más
						<svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>

				<!-- Erasmus+ FP -->
				<a href="/internacionalizacion#erasmus" class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 flex flex-col">
					<div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
						</svg>
					</div>
					<h3 class="font-bold text-lg mb-2">Erasmus+ FP</h3>
					<p class="text-blue-100 text-sm leading-relaxed flex-grow">Prácticas profesionales en empresas extranjeras que impulsan la empleabilidad de nuestros técnicos.</p>
					<span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
						Saber más
						<svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>

				<!-- eTwinning -->
				<a href="/internacionalizacion#etwinning" class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 flex flex-col">
					<div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
						</svg>
					</div>
					<h3 class="font-bold text-lg mb-2">eTwinning</h3>
					<p class="text-blue-100 text-sm leading-relaxed flex-grow">Colaboración digital y proyectos hermanados en tiempo real con aulas de toda Europa.</p>
					<span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
						Saber más
						<svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>

				<!-- Escuela Embajadora del Parlamento Europeo -->
				<a href="/internacionalizacion#embajadoras" class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 transition-all duration-300 hover:bg-white/15 hover:-translate-y-1 flex flex-col">
					<div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center mb-5">
						<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
						</svg>
					</div>
					<h3 class="font-bold text-lg mb-2">Escuela Embajadora</h3>
					<p class="text-blue-100 text-sm leading-relaxed flex-grow">Del Parlamento Europeo: formamos ciudadanía viviendo de cerca los valores y la democracia de la UE.</p>
					<span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white">
						Saber más
						<svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
					</span>
				</a>
			</div>

			<div class="mt-12">
				<a href="/internacionalizacion" class="inline-block bg-white text-blue-900 px-8 py-3 rounded-full font-semibold hover:bg-blue-50 transition-colors">
					Conoce nuestro programa internacional
				</a>
			</div>
		</div>
	</section>

	<!-- Orientación -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-teal-50 text-teal-700 text-sm font-semibold mb-4">
					Orientación y Comunidad
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Apoyo integral al alumnado
				</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Acompañamiento educativo, atención personalizada y participación activa de toda la comunidad escolar
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
				<!-- Acción Tutorial -->
				<div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl p-8 border border-emerald-100">
					<div class="w-12 h-12 bg-emerald-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Acción Tutorial</h3>
					<p class="text-gray-600 mb-4">Seguimiento personalizado del alumnado, técnicas de estudio y orientación académica y profesional para decidir su futuro.</p>
				</div>

				<!-- Atención a la Diversidad -->
				<div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-8 border border-blue-100">
					<div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Atención a la Diversidad</h3>
					<p class="text-gray-600 mb-4">Educación inclusiva con medidas y recursos específicos que se adaptan a las necesidades de cada estudiante.</p>
				</div>

				<!-- Comunidad -->
				<div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl p-8 border border-purple-100 md:col-span-2 lg:col-span-1">
					<div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Comunidad Educativa</h3>
					<p class="text-gray-600 mb-4">Familias, AMPA y Consejo de Estudiantes: una comunidad que participa y construye el centro día a día.</p>
				</div>
