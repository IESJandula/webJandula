---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import QuickAccess from '@components/QuickAccess.astro';
import CardNoticia from '@components/CardNoticia.astro';
import { getNoticias } from '@/lib/api';
import { caminosindex } from '@/lib/content';
import Chat from '@/components/Chat.astro';

const news = await getNoticias(5);

const sortedNews = [...news].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredNews = sortedNews.slice(0, 2);
const secondaryNews = sortedNews.slice(2, 5);
---


<!-- 	<Chat>

	</Chat> -->

<Layout title="Inicio">


	<Hero />
	
		<!-- Noticias -->
	{sortedNews.length > 0 && (
	<section class="container mx-auto px-4 py-20">
		<div class="flex flex-col md:flex-row justify-between items-end mb-8">
			<div>
				<h2 class="text-3xl font-bold text-gray-900">Últimas noticias</h2>
				<p class="text-gray-600 mt-2">Mantente al día con las noticias de nuestro centro</p>
			</div>
			<a href="/noticias" class="hidden md:inline-block text-blue-600 font-bold hover:underline">
				Ver todas las noticias &rarr;
			</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
			{featuredNews.map((item) => (
				<CardNoticia {...item} variant="featured" />
			))}
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
			{secondaryNews.map((item) => (
				<CardNoticia {...item} />
			))}
		</div>

		<div class="mt-8 text-center md:hidden">
			<a href="/noticias" class="btn-secondary inline-block border border-blue-600 text-blue-600 px-6 py-2 rounded-full font-bold">
				Ver todo
			</a>
		</div>
	</section>
	)}

	<!-- Oferta Educativa -->
	<section class="py-20 bg-gradient-to-br from-slate-50 to-blue-50">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-emerald-50 text-emerald-700 text-sm font-semibold mb-4">
					Oferta Educativa
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Encuentra tu camino
				</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Bachillerato y Formación Profesional de calidad con múltiples especialidades adaptadas al mercado laboral
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
					{caminosindex.map((camino) => (
						<a href={camino.url} class="block">
						<div class={`bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl hover:shadow-${camino.color} transition-all group`}>
							<div class="w-full rounded-full overflow-hidden bg-purple-800 flex items-center justify-center mb-6">
								<img src={camino.image} alt={camino.nombre} class="w-full hover:scale-110 object-cover object-center transition-all" loading="lazy" decoding="async" />
 							</div>
							<h3 class={`text-xl font-bold text-${camino.color} mb-3`}>{camino.nombre}</h3>
							<p class="text-gray-600 mb-4 text-sm">{camino.descripcion}</p>
						</div>
						</a>
					))}
			</div>

			<div class="text-center mt-12">
				<a href="/oferta" class="inline-block bg-emerald-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-emerald-700 transition-colors">
					Ver toda la oferta
				</a>
			</div>
		</div>
	</section>

	<!-- Proyectos -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-orange-50 text-orange-700 text-sm font-semibold mb-4">
					Proyectos
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Aprendemos haciendo
				</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Proyectos innovadores que enriquecen la formación de nuestro alumnado
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 p-8 text-white hover:scale-105 transition-transform">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Proyecto LINCE</h3>
						<p class="text-blue-100 mb-4">Participación en Shell Eco Marathon con vehículo de alta eficiencia</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>

				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-purple-600 to-pink-600 p-8 text-white hover:scale-105 transition-transform">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Biblioteca "Pasa Página"</h3>
						<p class="text-purple-100 mb-4">Espacio de lectura, cultura y publicación de revista escolar</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>

				<div class="group relative overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-600 to-teal-600 p-8 text-white hover:scale-105 transition-transform md:col-span-2 lg:col-span-1">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Erasmus+</h3>
						<p class="text-emerald-100 mb-4">Movilidad europea para alumnado y profesorado de FP</p>
						<span class="inline-flex items-center text-sm font-medium">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 ml-2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</span>
					</div>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="/proyectos" class="inline-block bg-orange-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-orange-700 transition-colors">
					Ver todos los proyectos
				</a>
			</div>
		</div>
	</section>

	<!-- Internacionalización -->
	<section class="py-20 bg-gradient-to-br from-blue-900 to-indigo-900 text-white">
		<div class="container mx-auto px-4">
			<div class="grid lg:grid-cols-2 gap-12 items-center">
				<div>
					<span class="inline-block px-4 py-2 rounded-full bg-blue-700 text-blue-100 text-sm font-semibold mb-4">
						Internacionalización
					</span>
					<h2 class="text-4xl font-bold mb-6">
						Abriendo fronteras, construyendo futuro
					</h2>
					<p class="text-lg text-blue-100 mb-8 leading-relaxed">
						Nuestro compromiso con la dimensión europea de la educación a través de programas de movilidad,
						proyectos eTwinning y como Escuela Embajadora del Parlamento Europeo.
					</p>
					<!-- TODO: Actualizar con datos reales de movilidades Erasmus+ -->
					<div class="grid grid-cols-2 gap-6 mb-8">
						<div class="bg-blue-800/50 rounded-xl p-4 backdrop-blur-sm">
							<p class="text-3xl font-bold mb-1">[N]</p>
							<p class="text-blue-200 text-sm">Participantes Erasmus+</p>
						</div>
						<div class="bg-blue-800/50 rounded-xl p-4 backdrop-blur-sm">
							<p class="text-3xl font-bold mb-1">[N]</p>
							<p class="text-blue-200 text-sm">Países destino</p>
						</div>
					</div>
					<a href="/internacionalizacion" class="inline-block bg-white text-blue-900 px-8 py-3 rounded-full font-semibold hover:bg-blue-50 transition-colors">
						Conoce más
					</a>
				</div>
				<div class="grid grid-cols-2 gap-4">
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20">
						<div class="text-4xl mb-3">🇪🇺</div>
						<h3 class="font-bold text-lg mb-2">Erasmus+</h3>
						<p class="text-blue-100 text-sm">Movilidad europea</p>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 mt-8">
						<div class="text-4xl mb-3">⭐</div>
						<h3 class="font-bold text-lg mb-2">EPAS</h3>
						<p class="text-blue-100 text-sm">Escuela Embajadora</p>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 -mt-4">
						<div class="text-4xl mb-3">💻</div>
						<h3 class="font-bold text-lg mb-2">eTwinning</h3>
						<p class="text-blue-100 text-sm">Proyectos digitales</p>
					</div>
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 mt-4">
						<div class="text-4xl mb-3">🌍</div>
						<h3 class="font-bold text-lg mb-2">Global</h3>
						<p class="text-blue-100 text-sm">Ciudadanía europea</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Orientación -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-2 rounded-full bg-teal-50 text-teal-700 text-sm font-semibold mb-4">
					Orientación y Comunidad
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-4">
					Apoyo integral al alumnado
				</h2>
				<p class="text-lg text-gray-600 max-w-2xl mx-auto">
					Acompañamiento educativo, atención personalizada y participación activa de toda la comunidad escolar
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
				<!-- Acción Tutorial -->
				<div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl p-8 border border-emerald-100">
					<div class="w-12 h-12 bg-emerald-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Acción Tutorial</h3>
					<p class="text-gray-600 mb-4">Acompañamiento personalizado, técnicas de estudio y orientación profesional</p>
				</div>

				<!-- Atención a la Diversidad -->
				<div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl p-8 border border-blue-100">
					<div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Atención a la Diversidad</h3>
					<p class="text-gray-600 mb-4">Educación inclusiva con medidas específicas y recursos especializados</p>
				</div>

				<!-- Comunidad -->
				<div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl p-8 border border-purple-100 md:col-span-2 lg:col-span-1">
					<div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-gray-900 mb-3">Comunidad Educativa</h3>
					<p class="text-gray-600 mb-4">AMPA, Consejo de Estudiantes y acceso Zona Profesorado</p>
				</div>
			</div>

			<div class="text-center mt-12">
				<a href="/orientacion" class="inline-block bg-teal-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-teal-700 transition-colors">
					Más información
				</a>
			</div>
		</div>
	</section>

	<!-- Secretaría Virtual -->
	<section class="py-20 bg-gradient-to-br from-slate-50 to-blue-50">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto text-center">
				<span class="inline-block px-4 py-2 rounded-full bg-blue-50 text-blue-700 text-sm font-semibold mb-4">
					Secretaría Virtual
				</span>
				<h2 class="text-4xl font-bold text-gray-900 mb-6">
					Gestión online al alcance de todos
				</h2>
				<p class="text-lg text-gray-600 mb-12">
					Accede a los servicios administrativos desde cualquier lugar y en cualquier momento
				</p>

				<div class="grid md:grid-cols-3 gap-6 mb-12">
					<div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-shadow">
						<div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-blue-600">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
							</svg>
						</div>
						<h3 class="font-bold text-gray-900 mb-2">Matrícula Online</h3>
						<p class="text-gray-600 text-sm">Realiza tu matrícula de forma rápida y sencilla</p>
					</div>

					<div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-shadow">
						<div class="w-14 h-14 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-emerald-600">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />
							</svg>
						</div>
						<h3 class="font-bold text-gray-900 mb-2">Solicitud de Documentos</h3>
						<p class="text-gray-600 text-sm">Certificados, títulos y documentación académica</p>
					</div>

					<div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-shadow">
						<div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-purple-600">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
							</svg>
						</div>
						<h3 class="font-bold text-gray-900 mb-2">Becas y Ayudas</h3>
						<p class="text-gray-600 text-sm">Información y solicitud de ayudas económicas</p>
					</div>
				</div>

				<a href="/secretaria_virtual" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-blue-700 transition-colors">
					Acceder a Secretaría Virtual
				</a>
			</div>
		</div>
	</section>



</Layout>