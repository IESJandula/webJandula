---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import QuickAccess from '@components/QuickAccess.astro';
import CardNoticia from '@components/CardNoticia.astro';
import { getNoticias } from '@/lib/api';
import Chat from '@/components/Chat.astro';

const news = await getNoticias(5);

const sortedNews = [...news].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredNews = sortedNews.slice(0, 2);
const secondaryNews = sortedNews.slice(2, 5);
---


	<Chat>

	</Chat>

<Layout title="Inicio">


	<Hero />
	
		<!-- Noticias -->
	{sortedNews.length > 0 && (
	<section class="container mx-auto px-4 py-20">
		<div class="flex flex-col md:flex-row justify-between items-end mb-8">
			<div>
				<h2 class="text-3xl font-bold text-slate-900">Últimas noticias</h2>
				<p class="text-slate-500 mt-2">Mantente al día con las noticias de nuestro centro</p>
			</div>
			<a href="/noticias" class="hidden md:inline-flex items-center gap-1.5 text-jandula-blue font-bold hover:text-jandula-blue/80 transition-colors">
				Ver todas las noticias
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
				</svg>
			</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
			{featuredNews.map((item) => (
				<CardNoticia {...item} variant="featured" />
			))}
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
			{secondaryNews.map((item) => (
				<CardNoticia {...item} />
			))}
		</div>

		<div class="mt-8 text-center md:hidden">
			<a href="/noticias" class="inline-flex items-center gap-2 border border-jandula-blue text-jandula-blue px-6 py-2.5 rounded-full font-bold text-sm hover:bg-jandula-blue hover:text-white transition-all duration-300">
				Ver todo
			</a>
		</div>
	</section>
	)}

	<!-- Oferta Educativa -->
	<section class="py-20 bg-slate-50">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-1.5 rounded-full bg-jandula-green/10 text-[#5a7118] text-sm font-semibold mb-4">
					Oferta Educativa
				</span>
				<h2 class="text-4xl font-bold text-slate-900 mb-4">
					Encuentra tu camino
				</h2>
				<p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
					Bachillerato y Formación Profesional de calidad con múltiples especialidades adaptadas al mercado laboral
				</p>
			</div>

			<!-- Grid asimétrico: rompe el patrón de 3 iguales -->
			<div class="grid lg:grid-cols-5 gap-5 max-w-6xl mx-auto">
				<!-- Bachillerato — columna estrecha -->
				<div class="lg:col-span-2 bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 group border border-slate-100">
					<div class="w-14 h-14 bg-jandula-blue/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-jandula-blue transition-colors duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-jandula-blue group-hover:text-white transition-colors duration-300">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-slate-900 mb-3">Bachillerato</h3>
					<p class="text-slate-500 mb-5 text-sm leading-relaxed">Ciencias y Tecnología, Humanidades y Ciencias Sociales</p>
					<span class="inline-block px-3 py-1 bg-jandula-blue/10 text-jandula-blue text-xs font-semibold rounded-full">2 años</span>
				</div>

				<!-- FP Grado Medio — columna ancha con fondo de marca -->
				<div class="lg:col-span-3 bg-jandula-blue rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 group text-white">
					<div class="w-14 h-14 bg-white/15 rounded-xl flex items-center justify-center mb-6">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-3">FP Grado Medio</h3>
					<p class="text-white/75 mb-5 text-sm leading-relaxed">Gestión Administrativa, Sistemas Microinformáticos, Electromecánica</p>
					<span class="inline-block px-3 py-1 bg-white/20 text-white text-xs font-semibold rounded-full">2 años</span>
				</div>

				<!-- FP Grado Superior — fila completa, layout horizontal -->
				<div class="lg:col-span-5 bg-white rounded-2xl p-7 shadow-sm hover:shadow-lg transition-all duration-300 group flex flex-col md:flex-row items-start md:items-center gap-6 border border-slate-100">
					<div class="w-14 h-14 bg-jandula-green/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-jandula-green transition-colors duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-jandula-green group-hover:text-slate-800 transition-colors duration-300">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
						</svg>
					</div>
					<div class="flex-grow">
						<h3 class="text-xl font-bold text-slate-900 mb-1">FP Grado Superior</h3>
						<p class="text-slate-500 text-sm">DAM, DAW, Administración y Finanzas, Automoción</p>
					</div>
					<div class="flex items-center gap-4 flex-shrink-0">
						<span class="inline-block px-3 py-1 bg-jandula-green/10 text-[#5a7118] text-xs font-semibold rounded-full">2 años</span>
						<a href="/oferta#ciclos" class="inline-flex items-center gap-1.5 text-sm font-bold text-jandula-blue hover:text-jandula-blue/80 transition-colors">
							Ver ciclos
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div class="text-center mt-10">
				<a href="/oferta" class="inline-flex items-center gap-2 bg-jandula-green text-slate-900 px-8 py-3.5 rounded-full font-bold text-sm hover:bg-jandula-green/90 transition-all duration-300 active:scale-[0.97] shadow-md">
					Ver toda la oferta
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<!-- Proyectos -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-1.5 rounded-full bg-jandula-blue/10 text-jandula-blue text-sm font-semibold mb-4">
					Proyectos
				</span>
				<h2 class="text-4xl font-bold text-slate-900 mb-4">
					Aprendemos haciendo
				</h2>
				<p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
					Proyectos innovadores que enriquecen la formación de nuestro alumnado
				</p>
			</div>

			<!-- Grid asimétrico: 3+2 columnas en lg -->
			<div class="grid md:grid-cols-2 lg:grid-cols-5 gap-5 max-w-6xl mx-auto">
				<div class="lg:col-span-3 group relative overflow-hidden rounded-2xl bg-gradient-to-br from-jandula-blue to-cyan-700 p-8 text-white hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-lg">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Proyecto LINCE</h3>
						<p class="text-white/75 mb-5 leading-relaxed text-sm">Participación en Shell Eco Marathon con vehículo de alta eficiencia</p>
						<a href="/proyectos" class="inline-flex items-center gap-1.5 text-sm font-bold text-white/90 hover:text-white transition-colors">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</a>
					</div>
				</div>

				<div class="lg:col-span-2 group relative overflow-hidden rounded-2xl bg-gradient-to-br from-violet-600 to-purple-700 p-8 text-white hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-lg">
					<div class="relative z-10">
						<h3 class="text-2xl font-bold mb-3">Biblioteca "Pasa Página"</h3>
						<p class="text-purple-100/80 mb-5 leading-relaxed text-sm">Espacio de lectura, cultura y publicación de revista escolar</p>
						<a href="/proyectos" class="inline-flex items-center gap-1.5 text-sm font-bold text-white/90 hover:text-white transition-colors">
							Descubre más
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</a>
					</div>
				</div>

				<div class="md:col-span-2 lg:col-span-5 group relative overflow-hidden rounded-2xl bg-gradient-to-br from-jandula-green to-emerald-600 p-8 text-white hover:-translate-y-1 transition-all duration-300 shadow-sm hover:shadow-lg flex flex-col md:flex-row md:items-center md:gap-8">
					<div class="relative z-10 flex-grow">
						<h3 class="text-2xl font-bold mb-2">Erasmus+</h3>
						<p class="text-white/80 leading-relaxed text-sm">Movilidad europea para alumnado y profesorado de FP — ampliamos horizontes</p>
					</div>
					<a href="/internacionalizacion" class="inline-flex items-center gap-1.5 text-sm font-bold text-slate-900 bg-white/25 hover:bg-white/35 transition-colors px-5 py-2.5 rounded-full mt-4 md:mt-0 self-start md:self-center flex-shrink-0">
						Ver programa
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
						</svg>
					</a>
				</div>
			</div>

			<div class="text-center mt-10">
				<a href="/proyectos" class="inline-flex items-center gap-2 bg-jandula-blue text-white px-8 py-3.5 rounded-full font-bold text-sm hover:bg-jandula-blue/90 transition-all duration-300 active:scale-[0.97]">
					Ver todos los proyectos
				</a>
			</div>
		</div>
	</section>

	<!-- Internacionalización -->
	<section class="py-20 bg-gradient-to-br from-jandula-blue to-slate-800 text-white">
		<div class="container mx-auto px-4">
			<div class="grid lg:grid-cols-2 gap-12 items-center">
				<div>
					<span class="inline-block px-4 py-1.5 rounded-full bg-jandula-blue/30 text-white/90 text-sm font-semibold mb-4">
						Internacionalización
					</span>
					<h2 class="text-4xl font-bold mb-6">
						Abriendo fronteras, construyendo futuro
					</h2>
					<p class="text-lg text-white/75 mb-8 leading-relaxed">
						Nuestro compromiso con la dimensión europea de la educación a través de programas de movilidad,
						proyectos eTwinning y como Escuela Embajadora del Parlamento Europeo.
					</p>
					<div class="grid grid-cols-2 gap-4 mb-8">
						<div class="bg-white/10 rounded-xl p-4 backdrop-blur-sm border border-white/10">
							<p class="text-3xl font-bold mb-1">[N]</p>
							<p class="text-white/60 text-sm">Participantes Erasmus+</p>
						</div>
						<div class="bg-white/10 rounded-xl p-4 backdrop-blur-sm border border-white/10">
							<p class="text-3xl font-bold mb-1">[N]</p>
							<p class="text-white/60 text-sm">Países destino</p>
						</div>
					</div>
					<a href="/internacionalizacion" class="inline-flex items-center gap-2 bg-white text-slate-900 px-7 py-3 rounded-full font-bold text-sm hover:bg-white/90 transition-colors active:scale-[0.97]">
						Conoce más
					</a>
				</div>
				<div class="grid grid-cols-2 gap-4">
					<!-- Erasmus+ -->
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15 hover:bg-white/15 transition-colors">
						<div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="w-5 h-5 text-white">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
							</svg>
						</div>
						<h3 class="font-bold text-lg mb-1">Erasmus+</h3>
						<p class="text-white/60 text-xs">Movilidad europea</p>
					</div>
					<!-- EPAS -->
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15 hover:bg-white/15 transition-colors mt-6">
						<div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="w-5 h-5 text-white">
								<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
							</svg>
						</div>
						<h3 class="font-bold text-lg mb-1">EPAS</h3>
						<p class="text-white/60 text-xs">Escuela Embajadora</p>
					</div>
					<!-- eTwinning -->
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15 hover:bg-white/15 transition-colors -mt-2">
						<div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="w-5 h-5 text-white">
								<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
							</svg>
						</div>
						<h3 class="font-bold text-lg mb-1">eTwinning</h3>
						<p class="text-white/60 text-xs">Proyectos digitales</p>
					</div>
					<!-- Global -->
					<div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15 hover:bg-white/15 transition-colors mt-2">
						<div class="w-10 h-10 bg-white/15 rounded-xl flex items-center justify-center mb-4">
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" class="w-5 h-5 text-white">
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
							</svg>
						</div>
						<h3 class="font-bold text-lg mb-1">Global</h3>
						<p class="text-white/60 text-xs">Ciudadanía europea</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Orientación -->
	<section class="py-20 bg-white">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-1.5 rounded-full bg-jandula-blue/10 text-jandula-blue text-sm font-semibold mb-4">
					Orientación y Comunidad
				</span>
				<h2 class="text-4xl font-bold text-slate-900 mb-4">
					Apoyo integral al alumnado
				</h2>
				<p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
					Acompañamiento educativo, atención personalizada y participación activa de toda la comunidad escolar
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
				<!-- Acción Tutorial -->
				<div class="bg-jandula-blue/5 rounded-2xl p-8 border border-jandula-blue/15 hover:border-jandula-blue/25 transition-colors group">
					<div class="w-12 h-12 bg-jandula-blue rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
				<div class="bg-jandula-blue/5 rounded-2xl p-8 border border-jandula-blue/15 hover:border-jandula-blue/25 transition-colors group">
					<div class="w-12 h-12 bg-jandula-blue rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-white">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
