---
import Layout from "@/layouts/Layout.astro";
import { ciclos } from "@/lib/content";
import CicloCard from "@components/CicloCard.astro";
import AsignaturasModal from "@components/AsignaturasModal.astro";

const familiasCiclosSet = new Set(ciclos.map((ciclo) => ciclo.familia));
const familiasCiclos = Array.from(familiasCiclosSet).sort((a, b) =>
  a.localeCompare(b, "es"),
);

---

<Layout title="Oferta Educativa - IES Jándula">

    <div
      class="mx-auto max-w-7xl px-6 pb-24 pt-4 sm:pb-32 lg:flex lg:px-8 lg:py-10"
    >
      <div
        class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl lg:flex-shrink-0"
      >
        <div class="mt-15 lg:mt-5">
          <a href="#" class="inline-flex space-x-6">
            <span
              class="inline-flex items-center space-x-2 text-sm font-medium leading-6 text-slate-600"
            >

          </a>
        </div>
        <h1
          class="mt-2 mb-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-6xl"
        >Construye tu futuro <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-emerald-600"
            >hoy mismo</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
El IES Jándula ofrece una <strong> diversificada oferta educativa</strong> que abarca la Educación Secundaria Obligatoria, Bachillerato y Formación Profesional en sus distintos niveles. Esta variedad permite al alumnado acceder a itinerarios formativos ajustados a sus capacidades, intereses y expectativas.
        </p>

      </div>


      <div
        class="mx-auto mt-16 flex max-w-2xl sm:mt-24 lg:ml-10 lg:mt-0 lg:mr-0 lg:max-w-none lg:flex-none xl:ml-32"
      >
        <div class="max-w-3xl flex-none sm:max-w-5xl lg:max-w-none">
          <div
            class="-m-2 rounded-2xl p-2 ring-1 ring-inset ring-slate-900/10 lg:-m-4 lg:rounded-3xl lg:p-4 bg-white/50 backdrop-blur-sm w-[90vw] md:w-[80vw] lg:w-[60vw] transition-all hover:shadow-xl hover:shadow-slate-200/50"
          >
            <img
              src="https://images.pexels.com/photos/3380743/pexels-photo-3380743.jpeg"
              alt="Estudiantes IES Jandula"
              class="w-[36rem] rounded-xl shadow-2xl ring-1 ring-slate-900/10 object-cover object-center h-[24rem]"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <section class="relative overflow-hidden py-14 sm:py-16">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-100 via-slate-50 to-white"></div>
    <div class="absolute -top-16 left-1/2 -z-10 h-48 w-48 -translate-x-1/2 rounded-full bg-blue-200/50 blur-3xl"></div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
          Un entorno pensado para aprender, crecer y decidir tu futuro
        </h2>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <article class="group rounded-2xl bg-gradient-to-br from-blue-50 via-white to-sky-50 p-6 shadow-sm ring-1 ring-blue-100/80 backdrop-blur transition-all hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-700 ring-1 ring-blue-100">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5a2 2 0 012-2h6a2 2 0 012 2v14a1 1 0 01-1.447.894L8 18l-3.553 1.894A1 1 0 013 19V5zm12 0a2 2 0 012-2h2a2 2 0 012 2v14a1 1 0 01-1.447.894L18 18l-1.553.829A1 1 0 0115 17.999V5z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900">Enseñanza Bilingüe</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Grupos bilingües (inglés) a lo largo de toda la etapa.
          </p>
        </article>

        <article class="group rounded-2xl bg-gradient-to-br from-emerald-50 via-white to-teal-50 p-6 shadow-sm ring-1 ring-emerald-100/80 backdrop-blur transition-all hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 ring-1 ring-emerald-100">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900">Atención a la Diversidad</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Oferta de Programas de Diversificación Curricular en 3º y 4º de la ESO.
          </p>
        </article>

        <article class="group rounded-2xl bg-gradient-to-br from-amber-50 via-white to-orange-50 p-6 shadow-sm ring-1 ring-amber-100/80 backdrop-blur transition-all hover:-translate-y-0.5 hover:shadow-md sm:col-span-2 lg:col-span-1">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-amber-700 ring-1 ring-amber-100">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8c-1.657 0-3 1.343-3 3 0 1.306.835 2.417 2 2.83V16a1 1 0 102 0v-2.17a3.001 3.001 0 001-5.83A2.994 2.994 0 0012 8z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6.343 6.343l1.414 1.414M17.657 6.343l-1.414 1.414M12 3v2m0 14v2M3 12h2m14 0h2M6.343 17.657l1.414-1.414M17.657 17.657l-1.414-1.414" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900">Innovación</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Materias optativas orientadas al futuro, como Computación y Robótica, Proyecto de Educación Plástica y Audiovisual e Introducción a la Tecnología.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Modern Grid ESO / Bachillerato -->
  <section id="eso" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mt-16 space-y-8 sm:mt-20">
        <!-- ESO -->
        <div class="relative overflow-hidden rounded-3xl bg-slate-50 shadow-sm ring-1 ring-slate-900/5 transition-all hover:shadow-md hover:bg-slate-100/80"
        >

        <!--Imagen "banner" de ESO -->
  <div class="relative z-10">
      <img
        src="images/Gemini_Generated_Image_om6cjvom6cjvom6c.webp"
        alt="Estudiantes en clase"
        class="w-full h-64 object-cover object-center rounded-tl-md rounded-tr-md shadow-lg ring-1 ring-slate-200 mb-10 transition-all hover:shadow-xl hover:ring-slate-300"
    >
  </div>
          <div
            class="absolute -right-20 -top-20 z-0 h-64 w-64 rounded-full bg-blue-100 blur-3xl opacity-60"
          >
          </div>
          <div class="relative z-10 px-8 pb-8">
            <div class="flex items-center gap-4 mb-6">
              <span
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-blue-600 shadow-sm ring-1 ring-slate-100"
              >
                <svg
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                  ></path></svg
                >
              </span>
              <h3 class="text-2xl font-bold text-slate-900">Educación Secundaria Obligatoria (E.S.O)</h3>
            </div>
            <p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-4xl">
              La <strong>Educación Secundaria Obligatoria (ESO)</strong> en el IES Jándula se articula en cuatro cursos organizados en dos ciclos, siguiendo el marco de la LOMLOE. Nuestro enfoque combina la excelencia académica con una atención personalizada para garantizar el éxito escolar de todo el alumnado.
            </p>

            <!-- Estructura y Materias -->
            <div class="mb-8">
              <h4 class="text-lg font-semibold text-slate-900 mb-4">Estructura y Materias</h4>
              <p class="text-slate-600 text-base leading-relaxed mb-4">
                La formación se divide en materias comunes que garantizan la base de conocimientos y materias optativas que permiten al alumno explorar sus intereses:
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 text-sm mb-3">Materias Comunes (Troncales)</h5>
                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Lengua Castellana y Literatura
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Matemáticas (académico o aplicado)
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Inglés (reforzado como centro bilingüe)
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Geografía e Historia
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Biología y Geología
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Física y Química (segundo ciclo)
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Educación Física
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-blue-600 flex-shrink-0"></span>
                      Educación Plástica/Música
                    </li>
                  </ul>
                </article>

                <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 text-sm mb-3">Materias Optativas</h5>
                  <p class="text-sm text-slate-600 mb-3">Ofrecemos una variada selección que incluye:</p>
                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-600 flex-shrink-0"></span>
                      Francés (Segunda Lengua Extranjera)
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-600 flex-shrink-0"></span>
                      Cultura Clásica
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-600 flex-shrink-0"></span>
                      Computación y Robótica
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-600 flex-shrink-0"></span>
                      Talleres de Matemáticas
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-600 flex-shrink-0"></span>
                      Talleres de Literatura
                    </li>
                  </ul>
                </article>
              </div>

              <!-- Enfoque Bilingüe -->
              <div class="rounded-2xl bg-blue-50 border-l-4 border-blue-600 p-5 mb-6">
                <h5 class="font-semibold text-blue-900 text-base mb-2">Enfoque Bilingüe</h5>
                <p class="text-blue-800 text-sm">
                  Como centro bilingüe, impartimos materias en inglés en grupos específicos, reforzando la competencia lingüística desde el primer curso. Esto prepara a nuestro alumnado para un mundo cada vez más globalizado.
                </p>
              </div>
            </div>

            <!-- Itinerarios en 4º -->
            <div class="mb-8">
              <h4 class="text-lg font-semibold text-slate-900 mb-4">Itinerarios en 4º de ESO</h4>
              <p class="text-slate-600 text-base leading-relaxed mb-4">
                En el último curso, el alumnado puede orientar sus estudios según sus expectativas futuras:
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 mb-3 flex items-center gap-2">
                    <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                    Enseñanzas Académicas
                  </h5>
                  <p class="text-sm text-slate-600">Orientada fundamentalmente hacia el acceso a Bachillerato.</p>
                </article>
                <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 mb-3 flex items-center gap-2">
                    <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                    Enseñanzas Aplicadas
                  </h5>
                  <p class="text-sm text-slate-600">Enfocada hacia el acceso a Ciclos Formativos de Grado Medio.</p>
                </article>
              </div>
            </div>

            <!-- Programas de Diversificación -->
            <div>
              <h4 class="text-lg font-semibold text-slate-900 mb-4">Programas de Diversificación y Apoyo</h4>
              <p class="text-slate-600 text-base leading-relaxed mb-4">
                Para el alumnado que requiere una metodología adaptada, contamos con:
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <article class="rounded-2xl bg-amber-50 p-5 ring-1 ring-amber-200/60 shadow-sm">
                  <h5 class="font-semibold text-amber-900 mb-2 text-base">Programas de Diversificación Curricular</h5>
                  <p class="text-sm text-amber-800 mb-3"><span class="font-semibold">Cursos:</span> 3º y 4º ESO</p>
                  <p class="text-sm text-amber-800">Organizados por ámbitos (Científico-Tecnológico y Lingüístico-Social) para facilitar la obtención del título de Graduado en ESO.</p>
                </article>
                <article class="rounded-2xl bg-slate-100 p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 mb-2 text-base">Programa ZTS</h5>
                  <p class="text-sm text-slate-700 mb-3"><span class="font-semibold">Cursos:</span> 1º y 2º ESO</p>
                  <p class="text-sm text-slate-700">Atención socioeducativa específica en los primeros cursos para apoyar la adaptación y el desarrollo integral del alumnado.</p>
                </article>
              </div>
            </div>
          </div>
        </div>

        <!-- Bachillerato debajo de ESO -->
        <div id="bachillerato" 
          class="pt-0 px-0 relative overflow-hidden rounded-3xl bg-slate-50 p-8 shadow-sm ring-1 ring-slate-900/5 transition-all hover:shadow-md hover:bg-slate-100/80"
        >
        <div class="relative z-10">
      <img
        src="/images/Selectividad-PEvAU_junio_Linares.jpg"
        alt="Estudiantes en clase"
        class="w-full h-64 object-cover object-center rounded-tl-md rounded-tr-md shadow-lg ring-1 ring-slate-200 mb-10 transition-all hover:shadow-xl hover:ring-slate-300"
    >
  </div>
          <div
            class="absolute -left-20 -top-20 z-0 h-56 w-56 rounded-full bg-indigo-100 blur-3xl opacity-60"
          >
          </div>
          <div class="relative z-10">
            <div class="flex items-center gap-4 mb-6">
              <span
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-indigo-600 shadow-sm ring-1 ring-slate-100"
              >
                <svg
                  class="h-8 w-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                  ></path>
                </svg>
              </span>
              <h3 class="text-2xl font-bold text-slate-900">Bachillerato</h3>
            </div>

            <p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-4xl">
              El <strong>Bachillerato</strong> en el IES Jándula tiene como objetivo proporcionar formación científica, humanística y tecnológica, así como las competencias necesarias para la educación superior. Ofrecemos dos modalidades principales en un entorno con refuerzo bilingüe.
            </p>

            <!-- Modalidades Disponibles -->
            <div class="mb-8">
              <h4 class="text-lg font-semibold text-slate-900 mb-4">Modalidades Disponibles</h4>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <!-- Ciencias y Tecnología -->
                <article class="rounded-2xl bg-slate-900 p-6 shadow-lg ring-1 ring-white/10">
                  <h5 class="text-base font-semibold text-white mb-3">Modalidad de Ciencias y Tecnología</h5>
                  <p class="text-sm text-slate-300 mb-4">Dirigida a estudiantes con interés en campos como la Ingeniería, Salud, Ciencias Puras y Arquitectura.</p>
                  <p class="text-xs font-semibold text-indigo-300 mb-3">Materias de Modalidad:</p>
                  <ul class="space-y-2 text-sm text-slate-200">
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Matemáticas I/II
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Física
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Química
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Biología y Geología
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Dibujo Técnico
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                      Tecnología Industrial
                    </li>
                  </ul>
                </article>

                <!-- Humanidades y Ciencias Sociales -->
                <article class="rounded-2xl bg-white p-6 ring-1 ring-slate-200/70 shadow-sm">
                  <h5 class="text-base font-semibold text-slate-900 mb-3">Modalidad de Humanidades y Ciencias Sociales</h5>
                  <p class="text-sm text-slate-600 mb-4">Orientada a estudiantes de Derecho, Economía, Periodismo, Filología, Traducción e Historia.</p>
                  <p class="text-xs font-semibold text-slate-700 mb-3">Materias de Modalidad:</p>
                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Latín I/II
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Matemáticas Aplicadas a las CCSS I/II
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Griego
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Economía
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Historia del Mundo Contemporáneo
                    </li>
                    <li class="flex items-start gap-2">
                      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-amber-500 flex-shrink-0"></span>
                      Geografía
                    </li>
                  </ul>
                </article>
              </div>
            </div>

            <!-- Materias Comunes y Optativas -->
            <div class="mb-8">
              <h4 class="text-lg font-semibold text-slate-900 mb-4">Materias Comunes y Optativas</h4>
              <p class="text-slate-600 text-base leading-relaxed mb-4">
                Todos los alumnos cursan materias transversales:
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200/60 shadow-sm">
                  <h5 class="font-semibold text-slate-900 text-sm mb-3">Materias Comunes</h5>
                  <ul class="space-y-2 text-sm text-slate-700">
