  <!-- Seccion Ciclos Moderno -->
  <section id="ciclos" class="py-24 bg-gradient-to-b from-slate-100 to-white relative overflow-hidden">


    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
      >
        <div class="max-w-2xl">
          <h2
            class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
          >
            Formación Profesional
          </h2>
          <p class="mt-4 text-md text-slate-600">
            La <strong>Formación Profesional (FP)</strong> del IES Jándula se distribuye en tres niveles: Grado Básico, Grado Medio y Grado Superior.<br>Ofrece una formación práctica y orientada al empleo en sectores estratégicos de la economía local, comarcal y provincial.
          </p>
        </div>
        <!-- Functional Filters -->
        <div class="flex flex-wrap gap-2" id="filters">
          <button
            data-filter="Todos"
            class="filter-btn px-4 py-2 rounded-full bg-slate-900 text-white text-sm font-medium transition-all shadow-sm hover:shadow-md border border-transparent"
          >
            Todos
          </button>
          {familiasCiclos.map((familia) => (
            <button
              data-filter={familia}
              class="filter-btn px-4 py-2 rounded-full bg-white border border-slate-200 text-slate-600 text-sm font-medium hover:border-slate-300 hover:bg-slate-50 transition-all cursor-pointer"
            >
              {familia}
            </button>
          ))}
        </div>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
        id="ciclos-grid"
      >
        {ciclos.map((dato) => (
          <CicloCard
            nombre={dato.nombre}
            nivel={dato.nivel}
            familia={dato.familia}
            descripcion={dato.descripcion}
            duracion={dato.duracion}
            turno={dato.turno}
            enlace={dato.enlace}
            bilingue={dato.bilingue}
            imagen={dato.imagen}
            asignaturas={dato.asignaturas}
          />
        ))}
      </div>
    </div>
  </section>

  <AsignaturasModal />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const filterButtons = document.querySelectorAll(".filter-btn");
      const cards = document.querySelectorAll(".ciclo-card");
      filterButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Remove active class from all buttons
          filterButtons.forEach((b) => {
            b.classList.remove(
              "bg-slate-900",
              "text-white",
              "border-transparent",
            );
            b.classList.add("bg-white", "text-slate-600", "border-slate-200");
          });

          // Add active class to clicked button
          btn.classList.remove(
            "bg-white",
            "text-slate-600",
            "border-slate-200",
          );
          btn.classList.add("bg-slate-900", "text-white", "border-transparent");

          const filterValue = btn.getAttribute("data-filter");

          cards.forEach((card: any) => {
            const cardFamilia = card.getAttribute("data-familia");

            if (filterValue === "Todos" || filterValue === cardFamilia) {
              card.style.display = "flex";
              // Add animation for appearance
              card.animate(
                [
                  { opacity: 0, transform: "translateY(10px)" },
                  { opacity: 1, transform: "translateY(0)" },
                ],
                {
                  duration: 300,
                  easing: "ease-out",
                },
              );
            } else {
              card.style.display = "none";
            }
          });
        });
      });
    });
  </script>
</Layout>
