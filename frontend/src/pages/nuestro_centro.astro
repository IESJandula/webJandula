---
import Layout from "@layouts/Layout.astro";




---

<Layout title="Conoce el centro">

  <!-- Modern Hero with Abstract Shapes -->
  <div class="relative isolate overflow-hidden bg-white">

    <div class="mx-auto max-w-7xl px-6 pb-12 pt-2 sm:pb-32 lg:flex lg:px-8 lg:py-40" >
        <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl lg:flex-shrink-0">
            <div class="hidden sm:mb-8 sm:flex sm:justify-normal">
            <span
            class="rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold leading-6 text-blue-700 ring-1 ring-inset ring-blue-700/10"
            >IES Jándula</span
            >
        </div>
        <h1 class="mt-10 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          Nuestro centro, <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-emerald-600"
            >tu comunidad</span
          >
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600">
          Conoce la organización, los órganos de participación y accede a toda
          la documentación oficial de nuestro instituto. Transparencia y
          compromiso educativo.
        </p>
        <div class="mt-10 flex items-center gap-x-6">
          <a
            href="#institucional"
            class="rounded-full bg-blue-800 px-8 py-3.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-800 transition-all"
          >Ver Institucional</a>
          <a
            href="#documentos"
            class="text-sm font-semibold leading-6 text-gray-900 flex items-center gap-2"
          >Documentos <span aria-hidden="true">→</span></a>
        </div>
      </div>
      <!-- Hero Image Composition -->
      <div
        class="mx-auto mt-16 flex max-w-2xl sm:mt-24 lg:ml-10 lg:mt-0 lg:mr-0 lg:max-w-none lg:flex-none xl:ml-32"
      >
        <div class="max-w-3xl flex-none sm:max-w-5xl lg:max-w-none">
          <div
            class="-m-2 rounded-2xl p-2 ring-1 ring-inset ring-slate-900/10 lg:-m-4 lg:rounded-3xl lg:p-4 bg-white/50 backdrop-blur-sm"
          >
            <img
              src="/images/bg-hero.webp"
              alt="Instalaciones IES Jandula"
              class="w-[36rem] rounded-xl shadow-2xl ring-1 ring-slate-900/10 object-cover object-center h-[24rem]"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Institucional Section (Bento Grid Style) -->
  <section id="institucional" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Institucional
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Estructura organizativa y atención a la comunidad.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Equipo Directivo (Card Grande) -->
        <div
          class="md:col-span-2 rounded-3xl bg-slate-50 p-8 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-md"
        >
          <h3
            class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-3"
          >
            <span class="p-2.5 bg-blue-100 text-blue-700 rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-6 h-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
                ></path>
              </svg>
            </span>
            Equipo Directivo
          </h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div
              class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 group hover:border-blue-200 transition-colors"
            >
              <p
                class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1"
              >
                Dirección
              </p>
              <p
                class="font-medium text-gray-900 group-hover:text-blue-700 transition-colors"
              >
                Juan Manuel Rubio Jiménez
              </p>
            </div>
            <div
              class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 group hover:border-blue-200 transition-colors"
            >
              <p
                class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1"
              >
                Jefatura de Estudios
              </p>
              <p
                class="font-medium text-gray-900 group-hover:text-blue-700 transition-colors"
              >
                Ana María López García
              </p>
            </div>
            <div
              class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 group hover:border-blue-200 transition-colors"
            >
              <p
                class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1"
              >
                Secretaría
              </p>
              <p
                class="font-medium text-gray-900 group-hover:text-blue-700 transition-colors"
              >
                Francisco Javier Molina Pérez
              </p>
            </div>
          </div>
          <p class="mt-6 text-sm text-gray-500 leading-relaxed">
            El equipo directivo coordina y dinamiza la actividad educativa del
            centro, garantizando el cumplimiento de las normas y fomentando la
            convivencia.
          </p>
        </div>

        <!-- Horarios (Card Vertical Dark) -->
        <div
          class="rounded-3xl bg-blue-900 p-8 shadow-xl text-white flex flex-col justify-between"
        >
          <div>
            <h3 class="text-xl font-bold mb-6 flex items-center gap-3">
              <span class="p-2 bg-blue-800 rounded-lg">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </span>
              Horarios
            </h3>
            <ul class="space-y-6">
              <li class="relative pl-4 border-l-2 border-emerald-400">
                <p
                  class="text-blue-200 text-xs uppercase font-bold tracking-wide mb-1"
                >
                  Jornada Lectiva
                </p>
                <p class="font-semibold text-lg">08:15 - 14:45</p>
              </li>
              <li class="relative pl-4 border-l-2 border-emerald-400">
                <p
                  class="text-blue-200 text-xs uppercase font-bold tracking-wide mb-1"
                >
                  Secretaría / Administración
                </p>
                <p class="font-semibold text-lg">09:00 - 14:00</p>
                <span class="text-xs text-blue-200 block mt-1"
                  >Lunes a Viernes</span
                >
              </li>
            </ul>
          </div>
          <div class="mt-8 pt-6 border-t border-blue-800">
            <p class="text-sm text-blue-100">
              Para tutorías con profesorado, consultar directamente a través de
              iPasen.
            </p>
          </div>
        </div>

        <!-- Consejo Escolar (Full width) -->
        <div
          class="md:col-span-3 rounded-3xl bg-white border border-slate-200 p-8 shadow-sm hover:shadow-md transition-shadow"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6"
          >
            <h3 class="text-xl font-bold text-gray-900 flex items-center gap-3">
              <span class="p-2 bg-emerald-100 text-emerald-700 rounded-lg">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
                  ></path>
                </svg>
              </span>
              Consejo Escolar
            </h3>
            <span
              class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20"
              >Órgano de Participación</span
            >
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
            <div class="text-center p-4 bg-slate-50 rounded-2xl">
              <p class="text-2xl font-bold text-gray-900">1</p>
              <p class="text-xs text-gray-500 uppercase mt-1">Presidencia</p>
            </div>
            <div class="text-center p-4 bg-slate-50 rounded-2xl">
              <p class="text-2xl font-bold text-gray-900">8</p>
              <p class="text-xs text-gray-500 uppercase mt-1">Profesorado</p>
            </div>
            <div class="text-center p-4 bg-slate-50 rounded-2xl">
              <p class="text-2xl font-bold text-gray-900">4</p>
              <p class="text-xs text-gray-500 uppercase mt-1">Familias</p>
            </div>
            <div class="text-center p-4 bg-slate-50 rounded-2xl">
              <p class="text-2xl font-bold text-gray-900">4</p>
              <p class="text-xs text-gray-500 uppercase mt-1">Alumnado</p>
            </div>
            <div class="text-center p-4 bg-slate-50 rounded-2xl">
              <p class="text-2xl font-bold text-gray-900">1</p>
              <p class="text-xs text-gray-500 uppercase mt-1">Ayuntamiento</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Documentos Section (Grid Clean) -->
  <section id="documentos" class="py-24 bg-slate-50 relative overflow-hidden">
    <div
      class="absolute inset-x-0 top-0 -z-10 h-[64rem] overflow-hidden bg-white"
    >
      <div
        class="absolute inset-x-0 top-0 h-[40rem] bg-gradient-to-b from-slate-100"
      >
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Documentación Oficial
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Accede a los planes y proyectos que rigen nuestro centro.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Doc Card 1 -->
        <div
          class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-lg"
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <div
                class="p-2 bg-blue-50 text-blue-600 rounded-lg group-hover:bg-blue-600 group-hover:text-white transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 006 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                  ></path>
                </svg>
              </div>
            </div>
            <h3
              class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors"
            >
              Proyecto de Centro
            </h3>
            <p class="mt-2 text-sm text-gray-500">
              Marco pedagógico y organizativo del instituto.
            </p>
          </div>
          <div class="mt-4 text-sm font-medium text-blue-600">
            Disponible en Secretaría
          </div>
        </div>

        <!-- Doc Card 2 -->
        <div
          class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-lg"
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <div
                class="p-2 bg-teal-50 text-teal-600 rounded-lg group-hover:bg-teal-600 group-hover:text-white transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3
              class="text-lg font-semibold text-gray-900 group-hover:text-teal-600 transition-colors"
            >
              Plan de Igualdad
            </h3>
            <p class="mt-2 text-sm text-gray-500">
              Medidas para la prevención de la discriminación.
            </p>
          </div>
          <div class="mt-4 text-sm font-medium text-teal-600">
            Disponible en Secretaría
          </div>
        </div>

        <!-- Doc Card 3 -->
        <div
          class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-lg"
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <div
                class="p-2 bg-emerald-50 text-emerald-600 rounded-lg group-hover:bg-emerald-600 group-hover:text-white transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.499 5.24 50.533 50.533 0 00-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                  ></path>
                </svg>
              </div>
            </div>
            <h3
              class="text-lg font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors"
            >
              Plan de Lectura
            </h3>
            <p class="mt-2 text-sm text-gray-500">
              Fomento de la lectura y la comprensión lectora.
            </p>
          </div>
          <div class="mt-4 text-sm font-medium text-emerald-600">
            Disponible en Secretaría
          </div>
        </div>

        <!-- Doc Card 4 -->
        <div
          class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-lg"
        >
          <div>
            <div class="flex items-center justify-between mb-4">
              <div
                class="p-2 bg-sky-50 text-sky-600 rounded-lg group-hover:bg-sky-600 group-hover:text-white transition-colors"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-6 h-6"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                  ></path>
                </svg>
              </div>
            </div>
            <h3
              class="text-lg font-semibold text-gray-900 group-hover:text-sky-600 transition-colors"
            >
              PAD
            </h3>
            <p class="mt-2 text-sm text-gray-500">
              Plan de Atención a la Diversidad del alumnado.
            </p>
          </div>
          <div class="mt-4 text-sm font-medium text-sky-600">
            Disponible en Secretaría
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
