---
import Layout from "@/layouts/Layout.astro"
import PageHero from "@/components/PageHero.astro";
import ProyectModal from "@/components/ProyectModal.astro";
import {proyectos} from "@/lib/proyects";

const categorias = [...new Set(proyectos.map((p) => p.categoria))];
---

<Layout title="Proyectos - IES Jándula">
  <PageHero
    title="Nuestros Proyectos"
    subtitle="En el IES Jándula creemos en una educación que va más allá del aula. Descubre las iniciativas que dan vida a nuestro centro."
    gradientClass="from-indigo-900 via-blue-800 to-sky-900"
    blobGradient="from-sky-400 to-indigo-300"
    subtitleClass="text-blue-100"
  >
    <Fragment slot="ctas">
      <a href="#proyectos" class="w-full sm:w-auto text-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-blue-900 shadow-sm hover:bg-blue-50 transition-all">
        Explorar proyectos
      </a>
    </Fragment>
  </PageHero>

  <div id="proyectos" class="bg-white py-16 sm:py-24 scroll-mt-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Filtros por categoría -->
      <div class="mb-12 flex flex-wrap items-center justify-center gap-2" role="group" aria-label="Filtrar proyectos por categoría">
        <button
          type="button"
          data-filter="todos"
          class="proyecto-filtro rounded-full px-4 py-2 text-sm font-semibold transition-all bg-blue-600 text-white shadow-sm"
        >
          Todos
        </button>
        {categorias.map((cat) => (
          <button
            type="button"
            data-filter={cat}
            class="proyecto-filtro rounded-full px-4 py-2 text-sm font-semibold transition-all bg-slate-100 text-slate-600 hover:bg-slate-200"
          >
            {cat}
          </button>
        ))}
      </div>

      <div id="proyectos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proyectos.map((pro) => (
          <div
            class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-xl hover:-translate-y-1"
            data-proyecto-card
            data-categoria={pro.categoria}
          >
            <button
              type="button"
              class="absolute inset-0 z-20 rounded-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
              data-proyecto-open
              data-proyecto-title={pro.nombre}
              data-proyecto-category={pro.categoria}
              data-proyecto-description={pro.descripcion}
              data-proyecto-summary={pro.resumen}
              data-proyecto-tags={JSON.stringify(pro.etiquetas ?? [])}
              data-proyecto-features={JSON.stringify(pro.caracteristicas ?? [])}
              data-proyecto-image={pro.portada}
              data-proyecto-images={JSON.stringify(pro.images ?? [])}
              aria-label={`Ver proyecto: ${pro.nombre}`}
            ></button>
            <!-- Image Container -->
            <div class="aspect-[4/3] overflow-hidden bg-slate-100 relative">
               <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent z-10 opacity-60 transition-opacity group-hover:opacity-40" aria-hidden="true"></div>
               <img
                src={pro.portada}
                alt={`Imagen del proyecto: ${pro.nombre} — ${pro.categoria}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
                decoding="async"
               />
               <!-- Category Badge on Image -->
               <div class="absolute top-4 left-4 z-20">
                    <span class="inline-flex items-center rounded-full bg-gradient-to-r from-blue-600/90 to-indigo-600/90 backdrop-blur-md px-3 py-1.5 text-xs font-bold tracking-wide text-white shadow-lg ring-1 ring-white/20" aria-hidden="true">
                        {pro.categoria}
                    </span>
               </div>
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-xl font-bold leading-6 text-slate-900 group-hover:text-blue-600 transition-colors">
                {pro.nombre}
              </h3>
              <p class="mt-4 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">
                {pro.resumen}
              </p>

              <!-- Tags -->
              <div class="mt-6 flex flex-wrap gap-2" aria-label="Etiquetas del proyecto">
                 {pro.etiquetas.map((etiqueta) => (
                   <span class="inline-flex items-center rounded-full bg-slate-50 px-2 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
                     {etiqueta}
                   </span>
                 ))}
              </div>
            </div>

            <!-- Arrow Action -->
            <div class="px-6 pb-6 pt-0 flex justify-end">
                <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-all" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
                    </svg>
                </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <ProyectModal id="proyectos" />

  <script>
    const filtros = document.querySelectorAll<HTMLButtonElement>(".proyecto-filtro");
    const cards = document.querySelectorAll<HTMLElement>("[data-proyecto-card]");

    const activo = ["bg-blue-600", "text-white", "shadow-sm"];
    const inactivo = ["bg-slate-100", "text-slate-600", "hover:bg-slate-200"];

    filtros.forEach((btn) => {
      btn.addEventListener("click", () => {
        filtros.forEach((b) => {
          b.classList.remove(...activo);
          b.classList.add(...inactivo);
        });
        btn.classList.remove(...inactivo);
        btn.classList.add(...activo);

        const filtro = btn.dataset.filter;
        cards.forEach((card) => {
          const visible = filtro === "todos" || card.dataset.categoria === filtro;
          card.classList.toggle("hidden", !visible);
        });
      });
    });
  </script>
</Layout>
