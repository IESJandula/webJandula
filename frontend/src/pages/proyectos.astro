---
import Layout from "@/layouts/Layout.astro"
import { projects } from "@/lib/content";

---

<Layout title="Proyectos - IES Jándula">
  <!-- Hero Section Minimal -->
  <div class="relative bg-white pt-24 pb-12 sm:pt-32">
     <div class="absolute inset-x-0 -top-40 -z-10 transform-gpu overflow-hidden blur-3xl sm:-top-80 opacity-20">
        <div class="relative left-[calc(50%-11rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 rotate-[30deg] bg-gradient-to-tr from-blue-200 to-emerald-200 sm:left-[calc(50%-30rem)] sm:w-[72.1875rem]"></div>
     </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <div class="mx-auto max-w-2xl">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-6xl">
           Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-blue-500">Proyectos</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          En el IES Jándula creemos en una educación que va más allá del aula. Descubre las iniciativas que dan vida a nuestro centro.
        </p>
      </div>
    </div>
  </div>

  <!-- Portfolio Grid -->
  <div class="bg-white pb-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-xl hover:-translate-y-1">
            <!-- Image Container -->
            <div class="aspect-[4/3] overflow-hidden bg-slate-100 relative">
               <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent z-10 opacity-60 transition-opacity group-hover:opacity-40" aria-hidden="true"></div>
               <img
                src={project.image}
                alt={`Imagen del proyecto: ${project.title} — ${project.category}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
                decoding="async"
               />
               <!-- Category Badge on Image -->
               <div class="absolute top-4 left-4 z-20">
                    <span class="inline-flex items-center rounded-md bg-white/90 backdrop-blur-sm px-2 py-1 text-xs font-medium text-slate-700 ring-1 ring-inset ring-slate-500/10" aria-hidden="true">
                        {project.category}
                    </span>
               </div>
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col p-6">
              <h3 class="text-xl font-bold leading-6 text-slate-900 group-hover:text-blue-600 transition-colors">
                <a href="#" aria-label={`Ver proyecto: ${project.title}`} class="focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 rounded">
                  <span class="absolute inset-0" aria-hidden="true"></span>
                  {project.title}
                </a>
              </h3>
              <p class="mt-4 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">
                {project.description}
              </p>

              <!-- Tags -->
              <div class="mt-6 flex flex-wrap gap-2" aria-label="Etiquetas del proyecto">
                 {project.tags.map(tag => (
                   <span class="inline-flex items-center rounded-full bg-slate-50 px-2 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
                     #{tag}
                   </span>
                 ))}
              </div>
            </div>

            <!-- Arrow Action -->
            <div class="px-6 pb-6 pt-0 flex justify-end">
                <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-all" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
                    </svg>
                </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>