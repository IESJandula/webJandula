---
import Layout from "@/layouts/Layout.astro"
import PageHero from "@/components/PageHero.astro";
import ProyectModal from "@/components/ProyectModal.astro";
import {proyectos} from "@/lib/proyects";
---

<Layout title="Proyectos - IES Jándula">
  <PageHero
    title="Nuestros Proyectos"
    subtitle="En el IES Jándula creemos en una educación que va más allá del aula. Descubre las iniciativas que dan vida a nuestro centro."
    gradientClass="from-indigo-900 via-blue-800 to-sky-900"
    blobGradient="from-sky-400 to-indigo-300"
    subtitleClass="text-blue-100"
    compact
  />

  <div id="proyectos" class="bg-white py-16 sm:py-24 scroll-mt-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <div id="proyectos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {proyectos.map((pro) => (
          <div
            class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-xl hover:-translate-y-1"
          >
            <button
              type="button"
              class="absolute inset-0 z-20 rounded-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2"
              data-proyecto-open
              data-proyecto-title={pro.nombre}
              data-proyecto-category={pro.categoria}
              data-proyecto-description={pro.descripcion}
              data-proyecto-summary={pro.resumen}
              data-proyecto-tags={JSON.stringify(pro.etiquetas ?? [])}
              data-proyecto-features={JSON.stringify(pro.caracteristicas ?? [])}
              data-proyecto-stats={JSON.stringify(pro.cifras ?? [])}
              data-proyecto-image={pro.portada}
              data-proyecto-images={JSON.stringify(pro.images ?? [])}
              aria-label={`Ver proyecto: ${pro.nombre}`}
            ></button>
            <!-- Image Container -->
            <div class="aspect-[4/3] overflow-hidden bg-slate-100">
               <img
                src={pro.portada}
                alt={`Imagen del proyecto: ${pro.nombre} — ${pro.categoria}`}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
               />
            </div>

            <!-- Content -->
            <div class="flex flex-1 flex-col p-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-blue-600">
                {pro.categoria}
              </p>
              <h3 class="mt-2 text-xl font-bold leading-snug text-slate-900 group-hover:text-blue-600 transition-colors">
                {pro.nombre}
              </h3>
              <p class="mt-3 flex-1 text-sm leading-6 text-slate-600 line-clamp-3">
                {pro.resumen}
              </p>

              <p class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600" aria-hidden="true">
                Ver proyecto
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:translate-x-1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <ProyectModal id="proyectos" />
</Layout>
