---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Orientación y Comunidad">

  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden bg-gradient-to-br from-emerald-900 via-teal-800 to-cyan-900">
    <div class="absolute inset-0 bg-[url('/images/bg-hero.webp')] bg-cover bg-center opacity-10"></div>
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 relative z-10">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
          Orientación y Comunidad
        </h1>
        <p class="mt-6 text-lg leading-8 text-emerald-100">
          Acompañamiento educativo, atención personalizada y participación activa de toda la comunidad escolar.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a
            href="#orientacion"
            class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-emerald-900 shadow-sm hover:bg-emerald-50 transition-all"
          >
            Ver Orientación
          </a>
          <a
            href="#comunidad"
            class="text-sm font-semibold leading-6 text-white flex items-center gap-2"
          >
            Comunidad Educativa <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative gradient blob -->
    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-emerald-400 to-cyan-300 opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]"></div>
    </div>
  </div>

  <!-- Orientación Section -->
  <section id="orientacion" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
          </svg>
          Departamento de Orientación
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Orientación Educativa
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Apoyo integral al alumnado en su desarrollo académico, personal y profesional.
        </p>
      </div>

      <!-- Acción Tutorial -->
      <div class="mb-16">
        <div class="rounded-3xl bg-gradient-to-br from-emerald-50 to-teal-50 p-8 sm:p-12 ring-1 ring-emerald-100">
          <div class="flex items-center gap-4 mb-8">
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-emerald-600 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900">Acción Tutorial</h3>
              <p class="text-emerald-700 text-sm font-medium">Acompañamiento personalizado</p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Columna 1 -->
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Tutorías individuales</h4>
                  <p class="text-sm text-gray-600">
                    Atención personalizada del tutor o tutora para resolver dudas académicas,
                    personales y organizativas del alumnado.
                  </p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-teal-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Tutorías grupales</h4>
                  <p class="text-sm text-gray-600">
                    Sesiones colectivas para trabajar competencias sociales, técnicas de estudio,
                    convivencia y orientación académico-profesional.
                  </p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.76c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Coordinación con familias</h4>
                  <p class="text-sm text-gray-600">
                    Comunicación fluida a través de iPasen, tutorías presenciales y telemáticas
                    para garantizar el seguimiento educativo.
                  </p>
                </div>
              </div>
            </div>

            <!-- Columna 2 -->
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Técnicas de estudio</h4>
                  <p class="text-sm text-gray-600">
                    Formación en metodologías de aprendizaje, organización del tiempo,
                    preparación de exámenes y estrategias de concentración.
                  </p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Orientación profesional</h4>
                  <p class="text-sm text-gray-600">
                    Asesoramiento sobre itinerarios formativos, opciones de FP, Bachillerato,
                    Universidad y salidas profesionales.
                  </p>
                </div>
              </div>

              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-purple-600 text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900 mb-2">Educación emocional</h4>
                  <p class="text-sm text-gray-600">
                    Desarrollo de competencias socioemocionales, gestión de conflictos,
                    autoestima y habilidades sociales.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contacto Orientación -->
          <div class="mt-10 pt-8 border-t border-emerald-200">
            <div class="text-center">
              <p class="text-sm font-medium text-gray-900 mb-1">¿Necesitas orientación?</p>
              <p class="text-sm text-gray-600">Contacta con el Departamento de Orientación a través de tu tutor/a o mediante iPasen</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Atención a la Diversidad -->
      <div>
        <div class="rounded-3xl bg-gradient-to-br from-blue-50 to-indigo-50 p-8 sm:p-12 ring-1 ring-blue-100">
          <div class="flex items-center gap-4 mb-8">
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-blue-600 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-gray-900">Atención a la Diversidad</h3>
              <p class="text-blue-700 text-sm font-medium">Educación inclusiva y personalizada</p>
            </div>
          </div>

          <div class="grid lg:grid-cols-3 gap-8">
            <!-- Medidas Generales -->
            <div class="rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <div class="p-2 bg-blue-100 text-blue-700 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Medidas Generales</h4>
              </div>
              <ul class="space-y-3 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  <span>Metodologías activas y cooperativas</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  <span>Adaptación de materiales didácticos</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  <span>Organización flexible de espacios</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-blue-600 mt-0.5">✓</span>
                  <span>Programas de refuerzo educativo</span>
                </li>
              </ul>
            </div>

            <!-- Medidas Específicas -->
            <div class="rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <div class="p-2 bg-indigo-100 text-indigo-700 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Medidas Específicas</h4>
              </div>
              <ul class="space-y-3 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-indigo-600 mt-0.5">✓</span>
                  <span>Adaptaciones Curriculares (AC)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-indigo-600 mt-0.5">✓</span>
                  <span>Programas de Profundización</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-indigo-600 mt-0.5">✓</span>
                  <span>Apoyo especializado (PT/AL)</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-indigo-600 mt-0.5">✓</span>
                  <span>Programas de enriquecimiento</span>
                </li>
              </ul>
            </div>

            <!-- Recursos -->
            <div class="rounded-2xl bg-white p-6 shadow-sm">
              <div class="flex items-center gap-3 mb-4">
                <div class="p-2 bg-purple-100 text-purple-700 rounded-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
                  </svg>
                </div>
                <h4 class="font-bold text-gray-900">Recursos Disponibles</h4>
              </div>
              <ul class="space-y-3 text-sm text-gray-600">
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 mt-0.5">✓</span>
                  <span>Aula de Apoyo a la Integración</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 mt-0.5">✓</span>
                  <span>Aula de Audición y Lenguaje</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 mt-0.5">✓</span>
                  <span>Materiales accesibles y TIC</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-purple-600 mt-0.5">✓</span>
