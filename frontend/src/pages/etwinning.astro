---
import Layout from "@layouts/Layout.astro";
import { cursosETwinning } from "@lib/etwinning";

const cursosRecientes = cursosETwinning.filter(c => c.curso !== 'Anteriores');
const cursosAnteriores = cursosETwinning.find(c => c.curso === 'Anteriores');
---

<Layout title="eTwinning en el IES Jándula">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-teal-700 via-teal-600 to-cyan-700 py-20">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full bg-white translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-white -translate-x-1/2 translate-y-1/2"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white">
          <span>🌐</span>
          <span>European School Education Platform</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
          eTwinning en el IES Jándula
        </h1>
        <p class="mt-6 text-lg text-teal-100">
          eTwinning conecta centros educativos de toda Europa para desarrollar proyectos colaborativos en línea. El IES Jándula lleva más de una década participando activamente, con proyectos reconocidos con Sello de Calidad Nacional y Europeo.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/internacionalizacion" class="inline-flex items-center gap-2 rounded-lg bg-white/20 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/30 transition-colors">
            ← Internacionalización
          </a>
          <a href="/erasmus" class="inline-flex items-center gap-2 rounded-lg bg-white text-teal-700 px-5 py-2.5 text-sm font-semibold hover:bg-teal-50 transition-colors">
            Ver movilidades Erasmus+ →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿Qué es eTwinning? -->
  <section class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-10">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-teal-100 flex items-center justify-center text-lg">🤝</div>
          <div>
            <h3 class="font-semibold text-gray-900 text-sm mb-1">Colaboración real</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Alumnado y profesorado trabajan conjuntamente con centros de otros países europeos en proyectos comunes.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-teal-100 flex items-center justify-center text-lg">💡</div>
          <div>
            <h3 class="font-semibold text-gray-900 text-sm mb-1">Competencia digital</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Los proyectos se desarrollan en el TwinSpace, un espacio virtual europeo donde alumnado y docentes colaboran en línea.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-teal-100 flex items-center justify-center text-lg">🏅</div>
          <div>
            <h3 class="font-semibold text-gray-900 text-sm mb-1">Sellos de Calidad</h3>
            <p class="text-xs text-gray-500 leading-relaxed">Los mejores proyectos reciben el Sello de Calidad eTwinning, un reconocimiento oficial de la Comisión Europea.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyectos recientes por curso -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Proyectos recientes</h2>
      <p class="text-gray-500 mb-12">Proyectos activos en la plataforma European School Education Platform (ESEP) desde 2022.</p>

      <div class="space-y-14">
        {cursosRecientes.map((curso) => (
          <div>
            <div class="flex items-center gap-4 mb-6">
              <span class="inline-flex items-center rounded-full bg-teal-600 px-4 py-1 text-sm font-semibold text-white">
                Curso {curso.curso}
              </span>
              <div class="flex-1 h-px bg-gray-200"></div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {curso.proyectos.map((proyecto) => (
                <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:shadow-md transition-shadow flex flex-col gap-3">
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-teal-600 text-xl">🌐</span>
                    {proyecto.sello && (
                      <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 text-yellow-800 px-2.5 py-0.5 text-xs font-medium">
                        ⭐ Sello de Calidad
                      </span>
                    )}
                  </div>
                  <div class="flex-1">
                    <h3 class="font-semibold text-gray-900 text-sm leading-snug">{proyecto.titulo}</h3>
                    <p class="mt-1.5 text-xs text-gray-500 leading-relaxed">{proyecto.descripcion}</p>
                  </div>
                  {proyecto.enlace && (
                    <a
                      href={proyecto.enlace}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-auto inline-flex items-center gap-1.5 text-xs font-medium text-teal-600 hover:text-teal-800 transition-colors"
                    >
                      Ver TwinSpace
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Proyectos anteriores (plataforma antigua) -->
  {cursosAnteriores && (
    <section class="bg-white py-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Proyectos anteriores</h2>
        <p class="text-gray-500 mb-8">Proyectos realizados en la plataforma eTwinning clásica (anterior a 2022). Los TwinSpaces pueden no estar disponibles en la nueva plataforma.</p>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {cursosAnteriores.proyectos.map((proyecto) => (
            <div class="group bg-gray-50 rounded-lg border border-gray-100 p-4 hover:bg-teal-50 hover:border-teal-100 transition-colors flex flex-col gap-2">
              <h3 class="font-medium text-gray-800 text-sm leading-snug group-hover:text-teal-900">{proyecto.titulo}</h3>
              <p class="text-xs text-gray-400 leading-relaxed flex-1 group-hover:text-gray-500">{proyecto.descripcion}</p>
              {proyecto.enlace && (
                <a
                  href={proyecto.enlace}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-xs text-teal-600 hover:text-teal-800 font-medium"
                >
                  TwinSpace
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-teal-700 py-12">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <p class="text-teal-100 text-sm mb-4">¿Quieres saber más sobre nuestros proyectos europeos?</p>
      <h2 class="text-2xl font-bold text-white mb-6">Conoce toda nuestra actividad internacional</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/internacionalizacion" class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-teal-700 hover:bg-teal-50 transition-colors">
          Internacionalización
        </a>
        <a href="/erasmus" class="inline-flex items-center gap-2 rounded-lg bg-teal-600 border border-teal-500 px-6 py-3 text-sm font-semibold text-white hover:bg-teal-500 transition-colors">
          Movilidades Erasmus+
        </a>
      </div>
    </div>
  </section>
</Layout>
