---
import Layout from '@/layouts/Layout.astro';
import { getNoticiaById, getNoticiasIds } from '@/lib/api';

function formatSpanishDate(dateInput: string): string {
  const date = new Date(dateInput);
  if (Number.isNaN(date.getTime())) return dateInput;

  const months = [
    'ENERO',
    'FEBRERO',
    'MARZO',
    'ABRIL',
    'MAYO',
    'JUNIO',
    'JULIO',
    'AGOSTO',
    'SEPTIEMBRE',
    'OCTUBRE',
    'NOVIEMBRE',
    'DICIEMBRE',
  ];

  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();

  return `${day} ${month}, ${year}`;
}

export async function getStaticPaths() {
  const ids = await getNoticiasIds(200);
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const noticia = id ? await getNoticiaById(id) : null;
const formattedDate = noticia ? formatSpanishDate(noticia.date) : '';
const sidePoster = noticia?.poster ?? null;
const bottomGallery = noticia?.gallery ?? [];
---

<Layout title={noticia?.title ?? 'Noticia no disponible'}>
  {!noticia ? (
    <section class="bg-slate-50 py-20">
      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-2xl rounded-3xl border border-slate-200 bg-white p-10 text-center shadow-sm">
          <h1 class="text-2xl md:text-3xl font-bold text-slate-900">Noticia no disponible</h1>
          <p class="mt-3 text-slate-600">
            Ahora mismo no se puede cargar esta noticia. Si el backend esta caido, la web seguira funcionando y podras volver a intentarlo mas tarde.
          </p>
          <a
            href="/noticias"
            class="mt-6 inline-flex items-center gap-2 rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 transition-colors"
          >
            <span aria-hidden="true">←</span>
            Volver a noticias
          </a>
        </div>
      </div>
    </section>
  ) : (
  <article class="bg-slate-50">
    <header class="relative overflow-hidden bg-gradient-to-b text-white">
      <div class="absolute -top-20 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-blue-500/20 blur-3xl"></div>
      <div class="container mx-auto px-4 py-9 md:py-9 relative">
        <a
          href="/noticias"
          class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-400 transition-colors"
        >
          <span aria-hidden="true">←</span>
          Volver a noticias
        </a>

        <div class="mt-6 flex flex-wrap items-center gap-3">
          <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-blue-100">
            {noticia.category}
          </span>

        </div>

        <h1 class="mt-6 max-w-4xl font-bold text-3xl md:text-5xl bg-clip-text text-transparent bg-gradient-to-r from-slate-950 via-slate-600 to-blue-700">
          {noticia.title}
        </h1>

        <div class="mt-4">
        <span class="text-m text-slate-500 mr-3">{formattedDate}</span>
        <span class="text-m text-blue-500">{noticia.author}</span>
        </div>

        <p class="mt-5 max-w-3xl text-base md:text-lg text-slate-500 leading-relaxed">
          {noticia.summary}
        </p>
      </div>
    </header>

    <div class="container mx-auto px-4 py-10 md:py-14">
      <div class="mx-auto">
        <img
          src={noticia.image}
          alt={`Imagen principal de la noticia: ${noticia.title}`}
          class="w-full max-h-[520px] object-cover shadow-xl ring-1 ring-slate-200"
          loading="eager"
          decoding="async"
        />

        <section class="mt-10">
          <h2 class="sr-only">Contenido de la noticia</h2>
          <div
            class:list={[
              'grid grid-cols-1 gap-8 items-start',
              sidePoster && 'lg:grid-cols-[minmax(0,1fr)_340px]',
            ]}
          >
            <div
              class="news-richtext text-base md:text-lg text-slate-700 leading-relaxed"
              set:html={noticia.body}
            ></div>

            {sidePoster && (
              <aside class="lg:sticky lg:top-24">
                <figure class="overflow-hidden rounded-2xl ring-1 ring-slate-200 bg-white shadow-md">
                  <img
                    src={sidePoster}
                    alt={`Cartel del evento: ${noticia.title}`}
                    class="w-full h-auto object-contain bg-white"
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
              </aside>
            )}
          </div>
        </section>

        {bottomGallery.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-5">Galeria</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {bottomGallery.map((src, index) => (
                <figure class="overflow-hidden rounded-2xl ring-1 ring-slate-200 bg-white shadow-sm">
                  <button
                    class="gallery-image-trigger block w-full"
                    data-image={src}
                    data-alt={`Imagen ${index + 1} de la noticia: ${noticia.title}`}
                    aria-label={`Abrir imagen ${index + 1} en grande`}
                  >
                    <img
                      src={src}
                      alt={`Imagen ${index + 1} de la noticia: ${noticia.title}`}
                      class="w-full h-56 object-cover hover:scale-[1.02] transition-transform duration-300"
                      loading="lazy"
                      decoding="async"
                    />
                  </button>
                </figure>
              ))}
            </div>
          </section>
        )}

        <div class="mt-8 flex justify-between items-center">
          <a
            href="/noticias"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 transition-colors"
          >
            <span aria-hidden="true">←</span>
            Todas las noticias
          </a>
        </div>
      </div>
    </div>
  </article>

  <div id="gallery-lightbox" class="fixed inset-0 z-[9999] hidden bg-black/85 p-4 md:p-8">
    <button
      id="gallery-lightbox-close"
      class="absolute top-4 right-4 rounded-full bg-white/15 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/25"
      aria-label="Cerrar visor"
    >
      Cerrar
    </button>
    <div class="h-full w-full flex items-center justify-center">
      <img id="gallery-lightbox-image" src="" alt="" class="max-h-full max-w-full object-contain" />
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = document.getElementById('gallery-lightbox');
      const lightboxImage = document.getElementById('gallery-lightbox-image') as HTMLImageElement | null;
      const closeButton = document.getElementById('gallery-lightbox-close');
      const triggers = document.querySelectorAll('.gallery-image-trigger');

      if (!lightbox || !lightboxImage) return;

      const closeLightbox = () => {
        lightbox.classList.add('hidden');
        lightboxImage.src = '';
        lightboxImage.alt = '';
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const element = trigger as HTMLElement;
          const src = element.getAttribute('data-image');
          const alt = element.getAttribute('data-alt') ?? 'Imagen ampliada';
          if (!src) return;

          lightboxImage.src = src;
          lightboxImage.alt = alt;
          lightbox.classList.remove('hidden');
        });
      });

      closeButton?.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (event) => {
        if (event.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLightbox();
      });
    });
  </script>
  )}
</Layout>
