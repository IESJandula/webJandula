---
import Layout from '@layouts/Layout.astro';
import PageHero from '@components/PageHero.astro';
import { proyectosErasmus, movilidadesFP, acreditacion } from '@lib/erasmus';
import { cursosETwinning } from '@lib/etwinning';

const totalMovilidades = proyectosErasmus.reduce((acc, p) => acc + p.movilidades.length, 0) + movilidadesFP.length;
const paisesErasmus = [...new Set([
  ...proyectosErasmus.flatMap(p => p.movilidades.flatMap(m => m.paises)),
  ...movilidadesFP.flatMap(m => m.paises),
])];
const totalProyectosETwinning = cursosETwinning.reduce((acc, c) => acc + c.proyectos.length, 0);

const movilidades = [
  { pais: 'Francia',   ciudad: 'Tours',         participantes: 17, anio: 2022, tipo: 'Alumnado',    bandera: '🇫🇷', lat: 47.394,  lng: 0.688   },
  { pais: 'Francia',   ciudad: 'Pacé',           participantes: 10, anio: 2024, tipo: 'Alumnado',    bandera: '🇫🇷', lat: 48.150,  lng: -1.778  },
  { pais: 'Alemania',  ciudad: 'Colonia',        participantes: 10, anio: 2023, tipo: 'Alumnado',    bandera: '🇩🇪', lat: 50.938,  lng: 6.960   },
  { pais: 'Alemania',  ciudad: 'Stolberg',       participantes: 12, anio: 2024, tipo: 'Alumnado',    bandera: '🇩🇪', lat: 50.772,  lng: 6.123   },
  { pais: 'Finlandia', ciudad: 'Forssa',         participantes: 9,  anio: 2024, tipo: 'Alumnado',    bandera: '🇫🇮', lat: 60.818,  lng: 23.626  },
  { pais: 'Italia',    ciudad: 'Vibo Valentia',  participantes: 4,  anio: 2024, tipo: 'Profesorado', bandera: '🇮🇹', lat: 38.676,  lng: 16.100  },
  { pais: 'Italia',    ciudad: 'Catania',        participantes: 2,  anio: 2024, tipo: 'FP',          bandera: '🇮🇹', lat: 37.502,  lng: 15.087  },
  { pais: 'Grecia',    ciudad: 'Atenas',         participantes: 2,  anio: 2024, tipo: 'Profesorado', bandera: '🇬🇷', lat: 37.983,  lng: 23.727  },
];
---

<Layout title="Internacionalización — IES Jándula">
  <link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <PageHero
    title="Internacionalización"
    subtitle="Abriendo fronteras, construyendo futuro. Nuestro compromiso con la dimensión europea de la educación."
    gradientClass="from-blue-900 via-blue-800 to-indigo-900"
  >
    <Fragment slot="ctas">
      <a href="#erasmus" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-blue-900 shadow-sm hover:bg-blue-50 transition-all">
        🇪🇺 Erasmus+
      </a>
      <a href="#etwinning" class="rounded-full bg-white/15 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/25 transition-all">
        🌐 eTwinning
      </a>
      <a href="#embajadoras" class="rounded-full bg-white/15 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/25 transition-all">
        🏛️ Escuelas Embajadoras
      </a>
      <a href="#bilingüismo" class="rounded-full bg-white/15 border border-white/30 px-5 py-2.5 text-sm font-semibold text-white hover:bg-white/25 transition-all">
        🗣️ Bilingüismo
      </a>
    </Fragment>
  </PageHero>

  <!-- Cifras reales -->
  <div class="bg-blue-700 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div>
          <div class="text-2xl font-bold">{totalMovilidades}+</div>
          <div class="text-xs text-blue-200">movilidades Erasmus+</div>
        </div>
        <div>
          <div class="text-2xl font-bold">{paisesErasmus.length}</div>
          <div class="text-xs text-blue-200">países socios</div>
        </div>
        <div>
          <div class="text-2xl font-bold">{totalProyectosETwinning}</div>
          <div class="text-xs text-blue-200">proyectos eTwinning</div>
        </div>
        <div>
          <div class="text-2xl font-bold">{acreditacion.desde}–{acreditacion.hasta}</div>
          <div class="text-xs text-blue-200">acreditación Erasmus+</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════ ERASMUS+ ══════════════════ -->
  <section id="erasmus" class="py-12 sm:py-16 lg:py-24 bg-white scroll-mt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <div class="mx-auto max-w-3xl text-center mb-10 sm:mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 ring-1 ring-blue-100 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
          Programa Erasmus+
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">Erasmus+ en el IES Jándula</h2>
        <p class="mt-4 text-sm sm:text-base lg:text-lg leading-relaxed text-gray-600">
          El IES Jándula participa en el programa <strong>Erasmus+</strong> como centro acreditado desde {acreditacion.desde}, abriendo oportunidades europeas para nuestro alumnado y profesorado a través de estancias formativas en distintos países de Europa.
        </p>
        <div class="mt-6">
          <a href="/erasmus" class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors shadow-sm">
            Ver todas las movilidades Erasmus+ →
          </a>
        </div>
      </div>

      <!-- 3 tarjetas -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 mb-10 sm:mb-16">
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-purple-50 to-pink-50 p-5 sm:p-6 ring-1 ring-purple-100">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-purple-100 text-purple-700">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
            </span>
            <h3 class="text-base sm:text-lg font-bold text-purple-900">Beneficios para el alumnado</h3>
          </div>
          <p class="text-xs sm:text-sm leading-relaxed text-gray-600">Nuestros estudiantes desarrollan <strong>competencias lingüísticas, digitales e interculturales</strong>, conviven con jóvenes de otros países y amplían su visión del mundo, mejorando sus perspectivas académicas y profesionales en Europa.</p>
        </div>
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 p-5 sm:p-6 ring-1 ring-blue-100">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-100 text-blue-700">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            </span>
            <h3 class="text-base sm:text-lg font-bold text-blue-900">FFE en empresas europeas</h3>
          </div>
          <p class="text-xs sm:text-sm leading-relaxed text-gray-600">El alumnado de FP realiza su <strong>Fase de Formación en Empresa (FFE)</strong> en empresas europeas a través de los programas <strong>Talentum</strong> y <strong>Jaén+</strong>. Estancias de 8 a 10 semanas en entornos profesionales reales.</p>
        </div>
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 p-5 sm:p-6 ring-1 ring-green-100 sm:col-span-2 lg:col-span-1">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </span>
            <h3 class="text-base sm:text-lg font-bold text-green-900">Movilidad del profesorado</h3>
          </div>
          <p class="text-xs sm:text-sm leading-relaxed text-gray-600">El profesorado realiza estancias de <em>job shadowing</em> en centros europeos de Grecia, Alemania y Francia, incorporando nuevas metodologías e innovaciones directamente al aula.</p>
        </div>
      </div>

      <!-- Mapa interactivo -->
      <div id="mapa" class="rounded-2xl sm:rounded-3xl bg-slate-50 p-4 sm:p-8 lg:p-12 shadow-sm ring-1 ring-gray-900/5 scroll-mt-24">
        <h3 class="text-lg sm:text-2xl font-bold text-gray-900 mb-1 sm:mb-2 text-center">Destinos de nuestras movilidades</h3>
        <p class="text-center text-gray-500 text-xs sm:text-sm mb-6 sm:mb-8">Haz clic en los marcadores para ver los detalles de cada destino</p>
        <div id="erasmus-map" class="w-full rounded-xl sm:rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-md" style="height: 300px; min-height: 300px;" role="img" aria-label="Mapa interactivo con los destinos Erasmus+ del IES Jándula"></div>

        <div class="grid gap-3 sm:gap-4 lg:gap-5 sm:grid-cols-2 lg:grid-cols-4 mt-8 sm:mt-10">
          {movilidades.map((m) => (
            <div class="group relative rounded-lg sm:rounded-2xl bg-white p-4 sm:p-5 shadow-sm ring-1 ring-gray-100 transition-all hover:shadow-lg hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-2 sm:mb-3">
                <span class="text-3xl sm:text-4xl" role="img" aria-label={m.pais}>{m.bandera}</span>
                <span class="rounded-full bg-blue-50 px-2 py-0.5 text-[10px] sm:text-xs font-semibold text-blue-700 ring-1 ring-blue-100">{m.anio}</span>
              </div>
              <h4 class="text-base sm:text-lg font-bold text-gray-900">{m.pais}</h4>
              <p class="text-xs sm:text-sm text-gray-500 mb-2 sm:mb-3">{m.ciudad}</p>
              <div class="flex items-center justify-between pt-2 sm:pt-3 border-t border-gray-50">
                <span class="text-xs text-gray-600"><strong class="text-gray-800">{m.participantes}</strong> pats.</span>
                <span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-1.5 py-0.5 rounded-full whitespace-nowrap">{m.tipo}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Galería -->
      <div class="mt-16 sm:mt-24">
        <div class="text-center mb-8 sm:mb-12">
          <h3 class="text-2xl sm:text-3xl font-bold tracking-tight text-gray-900">Nuestros Alumnos por Europa</h3>
          <p class="mt-3 sm:mt-4 text-sm sm:text-base text-gray-600 max-w-2xl mx-auto">
            Imágenes de las experiencias de nuestro alumnado durante sus movilidades Erasmus+.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          {[
            { src: '/images/Alemania.webp',   label: 'Colonia, Alemania',   flag: '🇩🇪', year: '2024' },
            { src: '/images/Alemania1.webp',  label: 'Colonia, Alemania',   flag: '🇩🇪', year: '2023' },
            { src: '/images/Alemania2.webp',  label: 'Colonia, Alemania',   flag: '🇩🇪', year: '2023' },
            { src: '/images/Francia.webp',    label: 'Tours, Francia',      flag: '🇫🇷', year: '2024' },
            { src: '/images/Italia.webp',     label: 'Italia',              flag: '🇮🇹', year: '2023' },
            { src: '/images/Finlandia.webp',  label: 'Forssa, Finlandia',   flag: '🇫🇮', year: '2023' },
            { src: '/images/Eslovaquia.webp', label: 'Eslovaquia',          flag: '🇸🇰', year: '2022' },
            { src: '/images/polonia.webp',    label: 'Arkadia, Polonia',    flag: '🇵🇱', year: '2024' },
          ].map(photo => (
            <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
              <img src={photo.src} alt={`Erasmus+ ${photo.label}`} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                <div class="flex items-center gap-2 mb-1">
                  <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                    {photo.flag} {photo.year}
                  </span>
                </div>
                <h4 class="text-white font-bold text-lg leading-tight">{photo.label}</h4>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════ eTWINNING ══════════════════ -->
  <section id="etwinning" class="py-12 sm:py-16 lg:py-24 bg-white scroll-mt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-10 sm:mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-4 py-2 text-sm font-semibold text-teal-700 ring-1 ring-teal-100 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>
          Proyectos eTwinning
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">Colaboración digital europea</h2>
        <p class="mt-4 text-sm sm:text-base lg:text-lg leading-relaxed text-gray-600">
          Conectando aulas, creando proyectos innovadores con centros de toda Europa en un entorno digital seguro integrado en Erasmus+.
        </p>
        <div class="mt-6">
          <a href="/etwinning" class="inline-flex items-center gap-2 rounded-full bg-teal-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-teal-700 transition-colors shadow-sm">
            Ver todos los proyectos eTwinning →
          </a>
        </div>
      </div>

      <div class="mt-12 sm:mt-16 rounded-3xl bg-gradient-to-br from-teal-50 to-cyan-50 p-6 sm:p-8 lg:p-12 ring-1 ring-teal-100">
        <h3 class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 mb-8 text-center">¿Por qué participamos en eTwinning?</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
          <div class="text-center">
            <div class="text-3xl sm:text-4xl mb-3">🌍</div>
            <h4 class="font-semibold text-gray-900 mb-2 text-sm sm:text-base">Apertura internacional</h4>
            <p class="text-xs sm:text-sm text-gray-600">Conexión con docentes y alumnos de toda Europa</p>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl mb-3">💻</div>
            <h4 class="font-semibold text-gray-900 mb-2 text-sm sm:text-base">Competencia digital</h4>
            <p class="text-xs sm:text-sm text-gray-600">Uso de herramientas TIC colaborativas avanzadas</p>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl mb-3">🗣️</div>
            <h4 class="font-semibold text-gray-900 mb-2 text-sm sm:text-base">Idiomas</h4>
            <p class="text-xs sm:text-sm text-gray-600">Práctica real de lenguas extranjeras en contexto</p>
          </div>
          <div class="text-center">
            <div class="text-3xl sm:text-4xl mb-3">🎯</div>
            <h4 class="font-semibold text-gray-900 mb-2 text-sm sm:text-base">Metodología activa</h4>
            <p class="text-xs sm:text-sm text-gray-600">Aprendizaje por proyectos y trabajo colaborativo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════ ESCUELAS EMBAJADORAS ══════════════════ -->
  <section id="embajadoras" class="py-16 sm:py-20 lg:py-24 bg-gradient-to-br from-slate-50 to-blue-50 scroll-mt-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-yellow-400 px-4 py-1.5 text-xs font-bold text-yellow-900 mb-4">
          🏛️ Parlamento Europeo
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">
          Escuelas Embajadoras del Parlamento Europeo
        </h2>
        <p class="mt-4 text-sm sm:text-base lg:text-lg leading-relaxed text-gray-600">
          Nuestro alumnado actúa como <strong>embajador de los valores europeos</strong> —democracia, participación, diversidad— organizando actividades de difusión en el centro y la comarca. Hoy somos <strong>Escuela Mentora MEPAS</strong>: guiamos a otros institutos andaluces en su camino hacia Europa.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 sm:gap-12 items-center">
        <div class="space-y-6 sm:space-y-8">
          <div class="flex gap-3 sm:gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 sm:h-12 w-10 sm:w-12 items-center justify-center rounded-lg sm:rounded-xl bg-blue-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1 sm:mb-2">Formación en valores europeos</h3>
              <p class="text-sm text-gray-600">Hasta 50 alumnos embajadores (4º ESO, Bachillerato o FP) aprenden sobre instituciones europeas, democracia parlamentaria y ciudadanía activa.</p>
            </div>
          </div>
          <div class="flex gap-3 sm:gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 sm:h-12 w-10 sm:w-12 items-center justify-center rounded-lg sm:rounded-xl bg-indigo-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1 sm:mb-2">Actividades de difusión</h3>
