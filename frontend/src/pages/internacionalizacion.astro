---
import Layout from '@layouts/Layout.astro';

// Datos de movilidades Erasmus+
const movilidades = [
  {
    pais: 'Alemania',
    ciudad: 'Berlín',
    participantes: 12,
    año: 2025,
    tipo: 'FP',
    bandera: '🇩🇪'
  },
  {
    pais: 'Italia',
    ciudad: 'Roma',
    participantes: 10,
    año: 2025,
    tipo: 'FP',
    bandera: '🇮🇹'
  },
  {
    pais: 'Francia',
    ciudad: 'París',
    participantes: 8,
    año: 2024,
    tipo: 'Profesorado',
    bandera: '🇫🇷'
  },
  {
    pais: 'Portugal',
    ciudad: 'Lisboa',
    participantes: 15,
    año: 2024,
    tipo: 'FP',
    bandera: '🇵🇹'
  },
  {
    pais: 'Polonia',
    ciudad: 'Cracovia',
    participantes: 6,
    año: 2023,
    tipo: 'Intercambio',
    bandera: '🇵🇱'
  }
];

// Proyectos eTwinning
const proyectoseTwinning = [
  {
    titulo: 'Digital Citizens of Europe',
    paises: ['España', 'Francia', 'Italia'],
    descripcion: 'Proyecto sobre ciudadanía digital y competencias tecnológicas en el contexto europeo.',
    año: '2024-2025',
    sello: 'Sello de Calidad Nacional'
  },
  {
    titulo: 'STEM for All',
    paises: ['España', 'Alemania', 'Polonia'],
    descripcion: 'Fomento de vocaciones STEM a través de proyectos colaborativos internacionales.',
    año: '2024-2025',
    sello: 'En desarrollo'
  },
  {
    titulo: 'Cultural Heritage 2.0',
    paises: ['España', 'Grecia', 'Portugal', 'Italia'],
    descripcion: 'Exploración del patrimonio cultural europeo mediante herramientas digitales.',
    año: '2023-2024',
    sello: 'Sello de Calidad Europeo'
  }
];
---

<Layout title="Internacionalización">

  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">
    <div class="absolute inset-0 bg-[url('/images/bg-hero.webp')] bg-cover bg-center opacity-10"></div>
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 relative z-10">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
          Internacionalización
        </h1>
        <p class="mt-6 text-lg leading-8 text-blue-100">
          Abriendo fronteras, construyendo futuro. Nuestro compromiso con la dimensión europea de la educación.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a
            href="#erasmus"
            class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-blue-900 shadow-sm hover:bg-blue-50 transition-all"
          >
            Ver Erasmus+
          </a>
          <a
            href="#etwinning"
            class="text-sm font-semibold leading-6 text-white flex items-center gap-2"
          >
            Proyectos eTwinning <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative gradient blob -->
    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-blue-400 to-indigo-300 opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]"></div>
    </div>
  </div>

  <!-- Erasmus+ Section -->
  <section id="erasmus" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 ring-1 ring-inset ring-blue-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          Programa Erasmus+
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Mapa de Movilidad Europea
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Experiencias de aprendizaje internacional para alumnado y profesorado de Formación Profesional.
        </p>
      </div>

      <!-- Estadísticas Erasmus+ -->
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 mb-16">
        <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 p-6 text-center ring-1 ring-blue-100">
          <div class="text-4xl font-bold text-blue-700">51</div>
          <div class="mt-2 text-sm font-medium text-gray-600">Participantes</div>
        </div>
        <div class="rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 p-6 text-center ring-1 ring-green-100">
          <div class="text-4xl font-bold text-green-700">5</div>
          <div class="mt-2 text-sm font-medium text-gray-600">Países destino</div>
        </div>
        <div class="rounded-2xl bg-gradient-to-br from-purple-50 to-pink-50 p-6 text-center ring-1 ring-purple-100">
          <div class="text-4xl font-bold text-purple-700">3</div>
          <div class="mt-2 text-sm font-medium text-gray-600">Años activos</div>
        </div>
        <div class="rounded-2xl bg-gradient-to-br from-orange-50 to-amber-50 p-6 text-center ring-1 ring-orange-100">
          <div class="text-4xl font-bold text-orange-700">100%</div>
          <div class="mt-2 text-sm font-medium text-gray-600">Satisfacción</div>
        </div>
      </div>

      <!-- Mapa de Movilidades -->
      <div class="rounded-3xl bg-slate-50 p-8 sm:p-12 shadow-sm ring-1 ring-gray-900/5">
        <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">
          Destinos de nuestras movilidades
        </h3>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {movilidades.map((movilidad) => (
            <div class="group relative rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-lg hover:scale-105">
              <div class="flex items-start justify-between mb-4">
                <div class="text-5xl">{movilidad.bandera}</div>
                <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-700">
                  {movilidad.año}
                </span>
              </div>
              <h4 class="text-xl font-bold text-gray-900 mb-1">
                {movilidad.pais}
              </h4>
              <p class="text-sm text-gray-600 mb-4">{movilidad.ciudad}</p>
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                  {movilidad.participantes} participantes
                </div>
                <span class="text-xs font-medium text-indigo-600">{movilidad.tipo}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Testimonios -->
      <div class="mt-16 grid gap-8 lg:grid-cols-2">
        <div class="rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-700 p-8 text-white shadow-xl">
          <div class="flex items-center gap-4 mb-6">
            <div class="h-12 w-12 rounded-full bg-white/20 flex items-center justify-center text-2xl">
              👨‍🎓
            </div>
            <div>
              <div class="font-semibold">Carlos M.</div>
              <div class="text-sm text-blue-200">Alumno CFGS DAM - Berlín 2025</div>
            </div>
          </div>
          <p class="text-blue-50 leading-relaxed">
            "La experiencia Erasmus+ en Alemania ha sido transformadora. He aprendido nuevas tecnologías,
            mejorado mi inglés y conocido profesionales increíbles. Recomiendo esta oportunidad a todos."
          </p>
        </div>
        <div class="rounded-2xl bg-gradient-to-br from-green-600 to-emerald-700 p-8 text-white shadow-xl">
          <div class="flex items-center gap-4 mb-6">
            <div class="h-12 w-12 rounded-full bg-white/20 flex items-center justify-center text-2xl">
              👩‍🏫
            </div>
            <div>
              <div class="font-semibold">María L.</div>
              <div class="text-sm text-green-200">Profesora - Job Shadowing París 2024</div>
            </div>
          </div>
          <p class="text-green-50 leading-relaxed">
            "El intercambio de buenas prácticas con centros europeos ha enriquecido enormemente mi práctica docente.
            He traído metodologías innovadoras que estamos implementando con éxito."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Escuelas Embajadoras del Parlamento Europeo -->
  <section id="embajadoras" class="py-24 bg-gradient-to-br from-slate-50 to-blue-50">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-yellow-50 px-4 py-2 text-sm font-semibold text-yellow-700 ring-1 ring-inset ring-yellow-700/10 mb-4">
          ⭐ Programa de Prestigio
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Escuelas Embajadoras del Parlamento Europeo
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Formando a futuros ciudadanos europeos comprometidos y activos.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Contenido -->
        <div class="space-y-8">
          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                Formación en valores europeos
              </h3>
              <p class="text-gray-600">
                Nuestros alumnos embajadores reciben formación sobre instituciones europeas,
                democracia participativa y ciudadanía activa.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                Actividades de difusión
              </h3>
              <p class="text-gray-600">
                Organización de charlas, debates y eventos para promover el conocimiento
                sobre la Unión Europea entre la comunidad educativa.
              </p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-purple-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                Red de centros europeos
              </h3>
              <p class="text-gray-600">
                Conexión con más de 1.500 centros embajadores de toda Europa,
                compartiendo proyectos y experiencias educativas.
              </p>
            </div>
          </div>
        </div>

        <!-- Visual -->
        <div class="relative">
          <div class="rounded-3xl bg-gradient-to-br from-blue-600 to-indigo-800 p-12 shadow-2xl">
            <div class="text-center text-white space-y-6">
              <div class="text-6xl mb-4">🇪🇺</div>
              <h3 class="text-2xl font-bold">Centro Embajador 2024-2026</h3>
              <div class="h-px bg-white/20 my-6"></div>
              <div class="grid grid-cols-2 gap-6 text-center">
                <div>
                  <div class="text-4xl font-bold">20+</div>
                  <div class="text-sm text-blue-200 mt-1">Alumnos embajadores</div>
                </div>
                <div>
                  <div class="text-4xl font-bold">15</div>
                  <div class="text-sm text-blue-200 mt-1">Actividades anuales</div>
                </div>
              </div>
              <div class="pt-6">
                <p class="text-blue-100 text-sm leading-relaxed">
                  Reconocidos oficialmente por la Oficina del Parlamento Europeo en España
                  por nuestra labor de promoción de los valores democráticos europeos.
                </p>
              </div>
            </div>
          </div>
          <!-- Decorative elements -->
          <div class="absolute -top-4 -right-4 w-24 h-24 bg-yellow-400 rounded-full opacity-20 blur-2xl"></div>
          <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-blue-400 rounded-full opacity-20 blur-2xl"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- eTwinning Section -->
  <section id="etwinning" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-purple-50 px-4 py-2 text-sm font-semibold text-purple-700 ring-1 ring-inset ring-purple-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
          </svg>
          Proyectos eTwinning
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Colaboración digital europea
        </h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Conectando aulas, creando proyectos innovadores con centros de toda Europa.
        </p>
      </div>

      <!-- Proyectos eTwinning Cards -->
      <div class="grid gap-8 lg:grid-cols-3">
        {proyectoseTwinning.map((proyecto, index) => (
          <div class="group relative rounded-3xl bg-white p-8 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-xl hover:-translate-y-1">
            <!-- Badge del sello -->
            <div class="absolute -top-4 right-6">
              <div class={`rounded-full px-4 py-2 text-xs font-bold shadow-lg ${
                proyecto.sello.includes('Europeo') ? 'bg-gradient-to-r from-yellow-400 to-orange-400 text-white' :
                proyecto.sello.includes('Nacional') ? 'bg-gradient-to-r from-blue-500 to-indigo-600 text-white' :
                'bg-gradient-to-r from-gray-400 to-gray-500 text-white'
              }`}>
                {proyecto.sello.includes('Calidad') ? '🏆' : '⚡'} {proyecto.sello}
              </div>
            </div>

            <div class="mb-6">
              <div class="text-sm font-medium text-gray-500 mb-2">{proyecto.año}</div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">
                {proyecto.titulo}
              </h3>
              <p class="text-gray-600 leading-relaxed">
                {proyecto.descripcion}
              </p>
            </div>

            <!-- Países participantes -->
            <div class="border-t border-gray-100 pt-6">
              <div class="text-sm font-medium text-gray-500 mb-3">Países socios:</div>
              <div class="flex flex-wrap gap-2">
                {proyecto.paises.map((pais) => (
                  <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                    {pais}
                  </span>
                ))}
              </div>
            </div>

            <!-- Hover effect indicator -->
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 to-purple-600 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-b-3xl"></div>
          </div>
        ))}
      </div>

      <!-- Beneficios eTwinning -->
      <div class="mt-16 rounded-3xl bg-gradient-to-br from-purple-50 to-pink-50 p-8 sm:p-12 ring-1 ring-purple-100">
        <h3 class="text-2xl font-bold text-gray-900 mb-8 text-center">
          ¿Por qué participamos en eTwinning?
        </h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-4xl mb-3">🌍</div>
            <h4 class="font-semibold text-gray-900 mb-2">Apertura internacional</h4>
            <p class="text-sm text-gray-600">Conexión con docentes y alumnos de toda Europa</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-3">💻</div>
            <h4 class="font-semibold text-gray-900 mb-2">Competencia digital</h4>
            <p class="text-sm text-gray-600">Uso de herramientas TIC colaborativas avanzadas</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-3">🗣️</div>
            <h4 class="font-semibold text-gray-900 mb-2">Idiomas</h4>
            <p class="text-sm text-gray-600">Práctica real de lenguas extranjeras en contexto</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-3">🎯</div>
            <h4 class="font-semibold text-gray-900 mb-2">Metodología activa</h4>
            <p class="text-sm text-gray-600">Aprendizaje por proyectos y trabajo colaborativo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gradient-to-r from-blue-600 to-indigo-700">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          ¿Quieres participar en nuestros proyectos internacionales?
        </h2>
        <p class="mt-4 text-lg leading-8 text-blue-100">
