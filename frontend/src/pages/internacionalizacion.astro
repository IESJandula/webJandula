---
import Layout from '@layouts/Layout.astro';


//PARTICIPANTES, PAÍSES DE DESTINO Y AÑOS DE ACTIVIDAD(Sustituir con datos reales del centro)
const estadisticasErasmus = {
  participantes: 124,
  paisesDestino: 6,
  anosActivos: 5,
};

// Destinos Erasmus+ — sustituir con datos reales del centro
const movilidades = [
  { pais: 'Alemania',    ciudad: 'Berlín',    participantes: 6,  anio: 2024, tipo: 'FP Dual',       bandera: '🇩🇪', lat: 52.52,  lng: 13.405 },
  { pais: 'Portugal',    ciudad: 'Lisboa',    participantes: 4,  anio: 2024, tipo: 'FP Medio',       bandera: '🇵🇹', lat: 38.717, lng: -9.139 },
  { pais: 'Italia',      ciudad: 'Roma',      participantes: 5,  anio: 2023, tipo: 'FP Superior',    bandera: '🇮🇹', lat: 41.902, lng: 12.496 },
  { pais: 'Francia',     ciudad: 'París',     participantes: 3,  anio: 2023, tipo: 'Profesorado',    bandera: '🇫🇷', lat: 48.857, lng: 2.347  },
  { pais: 'Países Bajos',ciudad: 'Ámsterdam', participantes: 4,  anio: 2025, tipo: 'FP Superior',    bandera: '🇳🇱', lat: 52.370, lng: 4.895  },
  { pais: 'Polonia',     ciudad: 'Cracovia',  participantes: 6,  anio: 2025, tipo: 'FP Medio',       bandera: '🇵🇱', lat: 50.064, lng: 19.945 },
];

// TODO: Actualizar con proyectos eTwinning reales del centro
const proyectoseTwinning: Array<{
  titulo: string;
  paises: string[];
  descripcion: string;
  anio: string;
  sello: string;
}> = [
  // {
  //   titulo: 'Nombre del proyecto',
  //   paises: ['España', 'Otro país'],
  //   descripcion: 'Descripción del proyecto...',
  //   anio: '2024-2025',
  //   sello: 'Estado del proyecto'
  // }
];




  //

---

<Layout title="Internacionalización">
  <link
    slot="head"
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">
    <div class="absolute inset-0 bg-[url('/images/bg-hero.webp')] bg-cover bg-center opacity-10"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24 lg:py-32 relative z-10">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold tracking-tight text-white">
          Internacionalización
        </h1>
        <p class="mt-4 sm:mt-6 text-base sm:text-lg lg:text-xl leading-relaxed sm:leading-8 text-blue-100">
          Abriendo fronteras, construyendo futuro. Nuestro compromiso con la dimensión europea de la educación.
        </p>
        <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#erasmus"
            class="w-full sm:w-auto rounded-full bg-white px-6 py-2.5 sm:py-3 text-sm font-semibold text-blue-900 shadow-sm hover:bg-blue-50 transition-all"
          >
            Ver Erasmus+
          </a>
          <a
            href="#etwinning"
            class="w-full sm:w-auto text-sm font-semibold leading-6 text-white flex items-center justify-center gap-2 hover:text-blue-100 transition-colors"
          >
            Proyectos eTwinning <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative gradient blob -->
    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-blue-400 to-indigo-300 opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]"></div>
    </div>
  </div>

  <!-- Erasmus+ Section -->
  <section id="erasmus" class="py-12 sm:py-16 lg:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-10 sm:mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold text-blue-700 ring-1 ring-inset ring-blue-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 sm:w-5 sm:h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          Programa Erasmus+
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">
          Mapa de Movilidad Europea
        </h2>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base lg:text-lg leading-relaxed text-gray-600">
          Experiencias de aprendizaje internacional para alumnado y profesorado de Formación Profesional.
        </p>
      </div>

      <!-- Estadísticas Erasmus+ -->
      <!-- TODO: Actualizar con estadísticas reales -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 mb-10 sm:mb-16">
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 p-4 sm:p-6 text-center ring-1 ring-blue-100">
          <div class="text-3xl sm:text-4xl font-bold text-blue-700">{estadisticasErasmus.participantes}</div>
          <div class="mt-1 sm:mt-2 text-xs sm:text-sm font-medium text-gray-600">Participantes</div>
        </div>
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 p-4 sm:p-6 text-center ring-1 ring-green-100">
          <div class="text-3xl sm:text-4xl font-bold text-green-700">{estadisticasErasmus.paisesDestino}</div>
          <div class="mt-1 sm:mt-2 text-xs sm:text-sm font-medium text-gray-600">Países destino</div>
        </div>
        <div class="rounded-xl sm:rounded-2xl bg-gradient-to-br from-purple-50 to-pink-50 p-4 sm:p-6 text-center ring-1 ring-purple-100">
          <div class="text-3xl sm:text-4xl font-bold text-purple-700">{estadisticasErasmus.anosActivos}</div>
          <div class="mt-1 sm:mt-2 text-xs sm:text-sm font-medium text-gray-600">Años activos</div>
        </div>

      </div>

      <!-- Mapa interactivo de Movilidades -->
      <div id="mapa" class="rounded-2xl sm:rounded-3xl bg-slate-50 p-4 sm:p-8 lg:p-12 shadow-sm ring-1 ring-gray-900/5 scroll-mt-24">
        <h3 class="text-lg sm:text-2xl font-bold text-gray-900 mb-1 sm:mb-2 text-center">
          Destinos de nuestras movilidades
        </h3>
        <p class="text-center text-gray-500 text-xs sm:text-sm mb-6 sm:mb-8">Haz clic en los marcadores para ver los detalles de cada destino</p>

        <!-- Mapa -->
        <div
          id="erasmus-map"
          class="w-full rounded-xl sm:rounded-2xl overflow-hidden ring-1 ring-gray-200 shadow-md"
          style="height: 300px; min-height: 300px;"
          role="img"
          aria-label="Mapa interactivo con los destinos Erasmus+ del IES Jándula"
        ></div>

        <!-- Leyenda accesible (fallback + complemento visual) -->
        <div class="mt-4 sm:mt-6 flex flex-wrap gap-2 sm:gap-3 justify-center" aria-hidden="true">
          {['FP Dual','FP Medio','FP Superior','Profesorado'].map(tipo => (
            <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-600 bg-white px-2 sm:px-3 py-1 sm:py-1.5 rounded-full ring-1 ring-gray-200">
              <span class="w-2 h-2 rounded-full bg-blue-600"></span>{tipo}
            </span>
          ))}
        </div>

        <!-- Tarjetas de destinos -->
        <div class="grid gap-3 sm:gap-4 lg:gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-8 sm:mt-10">
          {movilidades.map((m) => (
            <div class="group relative rounded-lg sm:rounded-2xl bg-white p-4 sm:p-5 shadow-sm ring-1 ring-gray-100 transition-all hover:shadow-lg hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-2 sm:mb-3">
                <span class="text-3xl sm:text-4xl" role="img" aria-label={m.pais}>{m.bandera}</span>
                <span class="rounded-full bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-100 text-[10px] sm:text-xs">{m.anio}</span>
              </div>
              <h4 class="text-base sm:text-lg font-bold text-gray-900">{m.pais}</h4>
              <p class="text-xs sm:text-sm text-gray-500 mb-2 sm:mb-3">{m.ciudad}</p>
              <div class="flex items-center justify-between pt-2 sm:pt-3 border-t border-gray-50">
                <span class="text-xs text-gray-600">
                  <strong class="text-gray-800">{m.participantes}</strong> pats.
                </span>
                <span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-1.5 py-0.5 rounded-full whitespace-nowrap">{m.tipo}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Galería de Experiencias Erasmus+ -->
      <div class="mt-16 sm:mt-24">
        <div class="text-center mb-8 sm:mb-12">
          <h3 class="text-2xl sm:text-3xl font-bold tracking-tight text-gray-900">
            Nuestros Alumnos por Europa
          </h3>
          <p class="mt-3 sm:mt-4 text-sm sm:text-base text-gray-600 max-w-2xl mx-auto">
            Imágenes de las experiencias de nuestro alumnado durante sus movilidades Erasmus+.
          </p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Alemania.png" 
              alt="Experiencia Erasmus Colonia, Alemania 2026" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇩🇪 2026
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Colonia, Alemania</h4>
            </div>
          </div>
          
          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Alemania1.png" 
              alt="Experiencia Erasmus Colonia, Alemania 2025" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇩🇪 2025
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Colonia, Alemania</h4>
            </div>
          </div>
          
          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Alemania2.png" 
              alt="Experiencia Erasmus Colonia, Alemania 2025" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇩🇪 2025
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Colonia, Alemania</h4>
            </div>
          </div>
          
          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Francia.png" 
              alt="Experiencia Erasmus Tours 2024" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇫🇷 2024
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Tours, Francia</h4>
            </div>
          </div>

          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Italia.png" 
              alt="Experiencia Erasmus Italia" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇮🇹 2023
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Italia</h4>
            </div>
          </div>

          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Finlandia.png" 
              alt="Experiencia Erasmus Finlandia" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇫🇮 2023
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Lyseokatu, Finlandia</h4>
            </div>
          </div>

          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/Eslovaquia.png" 
              alt="Experiencia Erasmus Eslovaquia" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇸🇰 2022
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Eslovaquia</h4>
            </div>
          </div>

          <div class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 shadow-sm ring-1 ring-gray-900/5">
            <img 
              src="/images/polonia.png" 
              alt="Experiencia Erasmus Arkadia, Polonia" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 via-gray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
               <div class="flex items-center gap-2 mb-1">
                 <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-md px-2 py-0.5 text-xs font-semibold text-white ring-1 ring-inset ring-white/30">
                   🇵🇱 2024
                 </span>
               </div>
               <h4 class="text-white font-bold text-lg leading-tight">Arkadia, Polonia</h4>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Escuelas Embajadoras del Parlamento Europeo -->
  <section id="embajadoras" class="py-16 sm:py-20 lg:py-24 bg-gradient-to-br from-slate-50 to-blue-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-12 sm:mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-yellow-50 px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold text-yellow-700 ring-1 ring-inset ring-yellow-700/10 mb-4">
          ⭐ Programa de Prestigio
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">
          Escuelas Embajadoras del Parlamento Europeo
        </h2>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base lg:text-lg leading-relaxed text-gray-600">
          Formando a futuros ciudadanos europeos comprometidos y activos.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 sm:gap-12 items-center">
        <!-- Contenido -->
        <div class="space-y-6 sm:space-y-8">
          <div class="flex gap-3 sm:gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 sm:h-12 w-10 sm:w-12 items-center justify-center rounded-lg sm:rounded-xl bg-blue-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-semibold text-gray-900 mb-1 sm:mb-2">
                Formación en valores europeos
              </h3>
              <p class="text-sm text-gray-600">
                Nuestros alumnos embajadores reciben formación sobre instituciones europeas,
                democracia participativa y ciudadanía activa.
              </p>
            </div>
          </div>

          <div class="flex gap-3 sm:gap-4">
            <div class="flex-shrink-0">
              <div class="flex h-10 sm:h-12 w-10 sm:w-12 items-center justify-center rounded-lg sm:rounded-xl bg-indigo-600 text-white">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6">
