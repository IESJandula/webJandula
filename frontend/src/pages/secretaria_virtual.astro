---
import { contacto } from "@/lib/content";
import Layout from '@layouts/Layout.astro';

const telefonoHref = `tel:${contacto.telefono.replace(/[^\d+]/g, '')}`;
const emailSecretariaHref = `mailto:${contacto.emailsecretaria}`;
---

<Layout title="Secretaría Virtual">

  <!-- Hero Section -->
  <div class="relative isolate overflow-hidden bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900">
    <div class="absolute inset-0 bg-[url('/images/bg-hero.webp')] bg-cover bg-center opacity-10"></div>
    <div class="mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8 relative z-10">
      <div class="mx-auto max-w-2xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-blue-700/50 px-4 py-2 text-sm font-semibold text-blue-100 ring-1 ring-inset ring-blue-400/30 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
          </svg>
          IES Jándula
        </div>
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
          Secretaría Virtual
        </h1>
        <p class="mt-6 text-lg leading-8 text-blue-100">
          Gestiona tus trámites administrativos online. Matrícula, certificados, becas y cita previa desde cualquier lugar.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a href="#tramites" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-blue-900 shadow-sm hover:bg-blue-50 transition-all">
            Ver Trámites
          </a>
          <a href="#cita-previa" class="rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-all ring-1 ring-blue-400">
            Pedir Cita Previa
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative gradient blob -->
    <div class="absolute inset-x-0 top-[calc(100%-13rem)] -z-10 transform-gpu overflow-hidden blur-3xl sm:top-[calc(100%-30rem)]">
      <div class="relative left-[calc(50%+3rem)] aspect-[1155/678] w-[36.125rem] -translate-x-1/2 bg-gradient-to-tr from-blue-400 to-indigo-300 opacity-20 sm:left-[calc(50%+36rem)] sm:w-[72.1875rem]"></div>
    </div>
  </div>

  <!-- ============================
       SECCIÓN: CITA PREVIA
       ============================ -->
  <section id="cita-previa" class="py-24 bg-white scroll-mt-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-4 py-2 text-sm font-semibold text-teal-700 ring-1 ring-inset ring-teal-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zm6.75-4.5h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V15zm0 2.25h.008v.008h-.008v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z" />
          </svg>
          Atención Personalizada
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Cita Previa</h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Reserva tu cita con la secretaría del centro para una atención personalizada y sin esperas.
        </p>
      </div>

      <div class="grid lg:grid-cols-5 gap-8 items-start">

        <!-- Formulario (3/5) -->
        <div class="lg:col-span-3 rounded-3xl bg-white p-8 shadow-sm ring-1 ring-gray-200">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Solicitar cita</h3>

          <form id="form-cita" class="space-y-5" novalidate>
            <!-- Nombre completo -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="nombre" class="block text-sm font-semibold text-gray-700 mb-1.5">Nombre <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  required
                  placeholder="Tu nombre"
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
                />
              </div>
              <div>
                <label for="apellidos" class="block text-sm font-semibold text-gray-700 mb-1.5">Apellidos <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="apellidos"
                  name="apellidos"
                  required
                  placeholder="Tus apellidos"
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
                />
              </div>
            </div>

            <!-- DNI y Teléfono -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="dni" class="block text-sm font-semibold text-gray-700 mb-1.5">DNI / NIE <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="dni"
                  name="dni"
                  required
                  placeholder="12345678A"
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
                />
              </div>
              <div>
                <label for="telefono" class="block text-sm font-semibold text-gray-700 mb-1.5">Teléfono <span class="text-red-500">*</span></label>
                <input
                  type="tel"
                  id="telefono"
                  name="telefono"
                  required
                  placeholder="600 000 000"
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
                />
              </div>
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Correo electrónico <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="correo@ejemplo.com"
                class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
              />
            </div>

            <!-- Motivo y Fecha/Hora -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="motivo" class="block text-sm font-semibold text-gray-700 mb-1.5">Motivo de la cita <span class="text-red-500">*</span></label>
                <select
                  id="motivo"
                  name="motivo"
                  required
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all appearance-none"
                >
                  <option value="" disabled selected>Selecciona un motivo</option>
                  <optgroup label="Trámites">
                    <option value="admision">Admisión</option>
                    <option value="matricula">Matrícula</option>
                    <option value="becas">Becas y Ayudas</option>
                  </optgroup>
                  <optgroup label="Certificados">
                    <option value="certificado-matricula">Certificado de matrícula</option>
                    <option value="certificado-notas">Certificado de notas</option>
                    <option value="historial">Historial académico</option>
                    <option value="titulo">Solicitud de título</option>
                    <option value="volante">Volante de escolarización</option>
                  </optgroup>
                  <optgroup label="Otros">
                    <option value="informacion">Información general</option>
                    <option value="otro">Otro motivo</option>
                  </optgroup>
                </select>
              </div>
              <div>
                <label for="fecha" class="block text-sm font-semibold text-gray-700 mb-1.5">Fecha preferente <span class="text-red-500">*</span></label>
                <input
                  type="date"
                  id="fecha"
                  name="fecha"
                  required
                  class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all"
                />
              </div>
            </div>

            <!-- Franja horaria -->
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Franja horaria preferente</label>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                {[
                  { id: 'franja-1', val: '9-10', label: '9:00 – 10:00' },
                  { id: 'franja-2', val: '10-11', label: '10:00 – 11:00' },
                  { id: 'franja-3', val: '11-12', label: '11:00 – 12:00' },
                  { id: 'franja-4', val: '12-14', label: '12:00 – 14:00' },
                ].map(f => (
                  <label class="relative flex cursor-pointer">
                    <input type="radio" name="franja" value={f.val} class="peer sr-only" />
                    <span class="w-full text-center text-sm font-medium px-3 py-2.5 rounded-xl border border-gray-200 bg-gray-50 text-gray-600 peer-checked:bg-teal-600 peer-checked:text-white peer-checked:border-teal-600 hover:border-teal-400 hover:bg-teal-50 transition-all cursor-pointer">
                      {f.label}
                    </span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Observaciones -->
            <div>
              <label for="observaciones" class="block text-sm font-semibold text-gray-700 mb-1.5">Observaciones</label>
              <textarea
                id="observaciones"
                name="observaciones"
                rows="3"
                placeholder="Indica cualquier información adicional que nos ayude a atenderte mejor..."
                class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-teal-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-teal-500/20 transition-all resize-none"
              ></textarea>
            </div>

            <!-- LOPD -->
            <div class="flex items-start gap-3 p-4 rounded-xl bg-gray-50 ring-1 ring-gray-100">
              <input
                type="checkbox"
                id="lopd"
                name="lopd"
                required
                class="mt-0.5 h-4 w-4 rounded border-gray-300 text-teal-600 focus:ring-teal-500 flex-shrink-0"
              />
              <label for="lopd" class="text-xs text-gray-600 leading-relaxed">
                He leído y acepto la <a href="/privacidad" class="text-teal-700 font-medium hover:underline">Política de Privacidad</a>.
                Los datos proporcionados serán tratados por el IES Jándula con la finalidad de gestionar tu cita, conforme al Reglamento General de Protección de Datos (RGPD).
              </label>
            </div>

            <!-- Botón enviar -->
            <button
              type="submit"
              id="btn-enviar"
              class="w-full flex items-center justify-center gap-2 rounded-xl bg-teal-600 px-6 py-4 text-sm font-semibold text-white hover:bg-teal-500 active:scale-95 transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 005.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              Solicitar Cita
            </button>

            <!-- Mensaje de éxito (oculto por defecto) -->
            <div id="msg-exito" class="hidden rounded-xl bg-teal-50 ring-1 ring-teal-200 p-5 items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-teal-600 flex-shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-semibold text-teal-800">¡Solicitud enviada correctamente!</p>
                <p class="text-sm text-teal-700 mt-1">Nos pondremos en contacto contigo en las próximas 24-48 horas para confirmar tu cita.</p>
              </div>
            </div>
          </form>
        </div>

        <!-- Info lateral (2/5) -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Horario -->
          <div class="rounded-2xl bg-gradient-to-br from-teal-600 to-emerald-700 text-white p-6 shadow-sm">
            <h4 class="font-bold text-lg mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Horario de atención
            </h4>
            <div class="space-y-3 text-sm">
              <div class="flex justify-between items-center pb-2 border-b border-teal-500">
                <span class="text-teal-100">Lunes – Viernes</span>
                <span class="font-bold">9:00 – 14:00</span>
              </div>
              <div class="flex justify-between items-center pb-2 border-b border-teal-500">
                <span class="text-teal-100">Lunes y Miércoles</span>
                <span class="font-bold">16:00 – 18:00</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-teal-100">Sábados y Domingos</span>
                <span class="font-bold text-teal-300">Cerrado</span>
              </div>
            </div>
          </div>

          <!-- Contacto directo -->
          <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-gray-100">
            <h4 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              Contacto directo
            </h4>
            <div class="space-y-3 text-sm">
              <div class="flex items-center gap-3 text-gray-700">
                <div class="w-8 h-8 bg-teal-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-teal-700">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Teléfono</p>
                  <a href={telefonoHref} class="font-semibold text-gray-900 hover:text-teal-700 transition-colors">{contacto.telefono}</a>
                </div>
              </div>
              <div class="flex items-center gap-3 text-gray-700">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-blue-700">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Email</p>
                  <a href={emailSecretariaHref} class="font-semibold text-gray-900 hover:text-blue-700 transition-colors text-xs">{contacto.emailsecretaria}</a>
                </div>
              </div>
              <div class="flex items-center gap-3 text-gray-700">
                <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-orange-700">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Dirección</p>
                  <p class="font-semibold text-gray-900 text-xs">{contacto.direccion}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Aviso -->
          <div class="rounded-2xl bg-amber-50 ring-1 ring-amber-200 p-5 flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <p class="text-xs text-amber-800">
              <strong>Nota:</strong> Esta solicitud no garantiza una hora fija. La secretaría confirmará la cita por teléfono o email en un plazo de 24-48 horas hábiles.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================
       SECCIÓN: TRÁMITES
       ============================ -->
  <section id="tramites" class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center mb-16">
        <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-700 ring-1 ring-inset ring-blue-700/10 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
          </svg>
          Gestiones Administrativas
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Trámites</h2>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Toda la información y accesos para realizar tus gestiones académicas de forma sencilla.
        </p>
      </div>

      <!-- Admisión -->
