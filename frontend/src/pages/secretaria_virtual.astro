<script>
  const form = document.getElementById('form-cita') as HTMLFormElement | null;
  const btnEnviar = document.getElementById('btn-enviar') as HTMLButtonElement | null;
  const msgExito = document.getElementById('msg-exito') as HTMLElement | null;
  const fechaInput = document.getElementById('fecha') as HTMLInputElement | null;

  // Bloquear fechas pasadas y fines de semana en el input de fecha
  if (fechaInput) {
    const hoy = new Date();
    // Sumar 1 día para que no se pueda pedir para hoy mismo
    hoy.setDate(hoy.getDate() + 1);
    const yyyy = hoy.getFullYear();
    const mm = String(hoy.getMonth() + 1).padStart(2, '0');
    const dd = String(hoy.getDate()).padStart(2, '0');
    fechaInput.min = `${yyyy}-${mm}-${dd}`;

    // Avanzar si el día seleccionado es fin de semana
    fechaInput.addEventListener('change', () => {
      const d = new Date(fechaInput.value + 'T00:00:00');
      const day = d.getDay(); // 0=dom, 6=sab
      if (day === 0) {
        d.setDate(d.getDate() + 1); // lunes
      } else if (day === 6) {
        d.setDate(d.getDate() + 2); // lunes
      }
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const dStr = String(d.getDate()).padStart(2, '0');
      fechaInput.value = `${y}-${m}-${dStr}`;
    });
  }

  // Manejar envío del formulario
  if (form && btnEnviar && msgExito) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Simular envío
      btnEnviar.disabled = true;
      btnEnviar.innerHTML = `
        <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Enviando...
      `;

      setTimeout(() => {
        form.reset();
        btnEnviar.classList.add('hidden');
        msgExito.classList.remove('hidden');
        msgExito.classList.add('flex');
        msgExito.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 1500);
    });
  }
</script>


